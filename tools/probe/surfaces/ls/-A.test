# ls -A: like -a but omit . and ..

file "visible.txt" "hello"
file ".hidden" "secret"
file ".config" "settings"
dir ".dotdir"

test args "."
  expect stdout not-empty
  expect stdout not-contains ".hidden"
  expect exit 0

test args "." "-A"
  expect stdout superset vs "."
  expect stdout contains ".hidden"
  expect stdout contains ".config"
  expect stdout not-contains ".."
  expect exit 0
