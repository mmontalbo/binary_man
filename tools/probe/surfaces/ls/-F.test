# ls -F: append indicator (*/=>@|) to entries

file "regular.txt" "hello"
dir "mydir"
file "script.sh" "#!/bin/sh"
props "script.sh" executable
link "mylink" -> "regular.txt"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-F"
  expect stdout preserved vs "."
  expect stdout contains "mydir/"
  expect stdout contains "script.sh*"
  expect stdout contains "mylink@"
  expect exit 0
