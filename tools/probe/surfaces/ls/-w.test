# ls -w: set output width

file "alpha.txt" "a"
file "beta.txt" "b"
file "gamma.txt" "c"
file "delta.txt" "d"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-w" "20"
  # FAILED: expected lines more, 0/2 discriminating
  #   [stdout identical — flag has no visible effect]
  #   Piped ls already outputs one-per-line. -w affects column layout
  #   which is only active when stdout is a terminal.
  #   UNTESTABLE in pipe mode — would need PTY or -C as control.
  # expect stdout lines more than "."
  expect stdout lines same as "."
  expect exit 0
