# ls -c: sort by ctime (status change time), newest first

# Setup order matters for ctime:
# 1. Create mmm.txt, then set mtime old (utimensat updates ctime)
# 2. Create zzz.txt (ctime = creation time, no props)
# 3. Create aaa.txt, then set mtime recent (rewrite updates ctime)
# So ctime newest→oldest: aaa (T4), zzz (T2), mmm (T1)
file "mmm.txt" "medium"
props "mmm.txt" mtime old
file "zzz.txt" "large content here"
file "aaa.txt" "small"
props "aaa.txt" mtime recent

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-c"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  # ctime order: aaa (latest metadata change), zzz (creation only), mmm (utimensat before zzz created)
  expect stdout line 1 contains "aaa.txt"
  expect stdout "zzz.txt" before "mmm.txt"
  expect exit 0
