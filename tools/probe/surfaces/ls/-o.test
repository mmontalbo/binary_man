# ls -o: like -l but do not list group information

file "alpha.txt" "hello"
file "beta.txt" "world"

test args "." "-l"
  expect stdout not-empty
  expect exit 0

test args "." "-o"
  # -o omits group, keeps owner → 3 fields before size
  expect stdout lines same as "." "-l"
  expect stdout contains "alpha.txt"
  expect stdout every-line-matches "^(total \d+|[^ ]+ +\d+ +\S+ +\d)"
  # NOTE: same regex as -g/-G. See -g.test for why these remain confused.
  expect exit 0
