# ls -g: like -l but do not list owner

file "alpha.txt" "hello"
file "beta.txt" "world"

test args "." "-l"
  expect stdout not-empty
  expect exit 0

test args "." "-g"
  # -g omits owner, keeps group → 3 fields before size
  expect stdout lines same as "." "-l"
  expect stdout contains "alpha.txt"
  expect stdout every-line-matches "^(total \d+|[^ ]+ +\d+ +\S+ +\d)"
  # NOTE: -g/-o/-G all produce 3 fields before size → same regex.
  # Distinguishing requires system-specific field-value checks.
  # Remaining confusion with -o and -G is a measurement ceiling.
  expect exit 0
