# ls -x: list entries by lines instead of by columns

file "alpha.txt" "a"
file "beta.txt" "b"
file "gamma.txt" "c"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-x"
  # FAILED (1): lines same → 1 vs 3 (piped ls is one-per-line, -x joins them)
  # FAILED (2): collapsed → Preserved (filenames still appear in single line)
  # expect stdout collapsed vs "."
  expect stdout preserved vs "."
  expect stdout lines fewer than "."
  # Distinguish from -m: -x uses spaces, -m uses commas
  expect stdout not-contains ","
  expect exit 0
