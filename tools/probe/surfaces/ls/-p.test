# ls -p: append / to directories

file "regular.txt" "hello"
dir "mydir"
dir "another_dir"
file "script.sh" "#!/bin/sh"
props "script.sh" executable

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-p"
  expect stdout preserved vs "."
  expect stdout contains "mydir/"
  expect stdout contains "another_dir/"
  # -p only marks directories, unlike -F which also marks executables
  expect stdout not-contains "script.sh*"
  expect stdout lines same as "."
  expect exit 0
