# ls -I: do not list entries matching pattern

file "keep.txt" "keep"
file "skip.log" "skip"
file "also.log" "skip too"
file "other.txt" "other"

test args "."
  expect stdout not-empty
  expect stdout contains "skip.log"
  expect exit 0

test args "." "-I" "*.log"
  expect stdout subset vs "."
  expect stdout not-contains "skip.log"
  expect stdout not-contains "also.log"
  expect stdout contains "keep.txt"
  expect exit 0
