# ls -R: list subdirectories recursively

file "top.txt" "top"
dir "subdir"
file "subdir/nested.txt" "nested"
dir "subdir/deep"
file "subdir/deep/bottom.txt" "bottom"

test args "."
  expect stdout not-empty
  expect stdout not-contains "nested.txt"
  expect exit 0

test args "." "-R"
  expect stdout superset vs "."
  expect stdout contains "nested.txt"
  expect stdout contains "bottom.txt"
  expect stdout lines more than "."
  expect exit 0
