# ls -U: do not sort; list entries in directory order

file "zz_last.txt" "z"
file "aa_first.txt" "a"
file "mm_middle.txt" "m"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-U"
  # Directory order is filesystem-dependent (htree hashing on ext4).
  # Cannot pin specific positions. Can only verify different from alpha.
  # FAILED: line 1 contains "zz_last.txt" — htree doesn't use creation order
  # expect stdout line 1 contains "zz_last.txt"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  expect exit 0
