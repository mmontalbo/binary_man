# ls -L: dereference symlinks (show target info, not link info)

file "target.txt" "hello"
dir "realdir"
link "mylink" -> "target.txt"
link "dirlink" -> "realdir"

test args "." "-l"
  expect stdout not-empty
  expect stdout contains "->"
  expect exit 0

test args "." "-lL"
  # FAILED: expected preserved, got Complement — dereferencing changes link lines
  # expect stdout preserved vs "." "-l"
  expect stdout lines same as "." "-l"
  expect stdout not-contains "->"
  expect stdout contains "mylink"
  # Dereferenced link shows regular file permissions, not lrwxrwxrwx
  expect stdout not-contains "lrwx"
  # Output is still long-listing format (distinguishes from -s which has "size filename")
  expect stdout every-line-matches "^(total \d+|[^ ]+ +\d+ +\S+ +\S+ +\d)"
  expect exit 0
