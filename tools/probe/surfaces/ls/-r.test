# ls -r: reverse sort order

file "alpha.txt" "a"
file "beta.txt" "b"
file "gamma.txt" "c"
file "delta.txt" "d"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-r"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  # Pin the actual reverse-alpha order
  expect stdout line 1 contains "gamma.txt"
  expect stdout line 4 contains "alpha.txt"
  expect stdout "gamma.txt" before "alpha.txt"
  expect exit 0
