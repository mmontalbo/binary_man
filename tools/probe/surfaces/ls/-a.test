# ls -a: show hidden files (entries starting with .)

file "visible.txt" "hello"
file "another.txt" "world"
file ".hidden" "secret"
file ".config" "settings"
dir ".dotdir"

test args "."
  expect stdout not-empty
  expect stdout not-contains ".hidden"
  expect stdout not-contains ".config"
  expect exit 0

test args "." "-a"
  expect stdout superset vs "."
  expect stdout contains ".hidden"
  expect stdout contains ".config"
  expect stdout contains "."
  expect stdout contains ".."
  # Distinguish from -f: -a sorts alphabetically, so .config before .hidden
  expect stdout ".config" before "visible.txt"
  expect exit 0
