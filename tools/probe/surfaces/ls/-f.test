# ls -f: do not sort, enable -aU, disable -ls --color

file "visible.txt" "hello"
file ".hidden" "secret"
dir "subdir"

test args "."
  expect stdout not-empty
  expect stdout not-contains ".hidden"
  expect exit 0

test args "." "-f"
  expect stdout superset vs "."
  expect stdout contains ".hidden"
  expect stdout contains "."
  expect stdout contains ".."
  # -f disables sorting. Files appear in creation order, not alphabetical.
  # In alpha order: .hidden before visible.txt. In creation order: visible.txt first.
  expect stdout "visible.txt" before ".hidden"
  expect exit 0
