# ls -X: sort by extension

file "file.c" "c code"
file "file.a" "archive"
file "file.z" "compressed"
file "file.b" "binary"
dir "noext_dir"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-X"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  # Extension sort: noext_dir (no ext first), file.a, file.b, file.c, file.z
  expect stdout line 1 contains "noext_dir"
  expect stdout "file.a" before "file.c"
  # Distinguish from -S: extension sort puts file.z last, size sort puts it second
  expect stdout "file.c" before "file.z"
  expect exit 0
