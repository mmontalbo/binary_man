# ls -t: sort by modification time, newest first

# 3 files with distinct mtimes and names that don't correlate with time order
file "mmm.txt" "medium"
props "mmm.txt" mtime old
file "zzz.txt" "large content here"
file "aaa.txt" "small"
props "aaa.txt" mtime recent

# Alpha order: aaa, mmm, zzz
# mtime order (newest first): aaa (recent), zzz (just created), mmm (year 2000)

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-t"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  # Pin mtime order: aaa (recent) first, mmm (old) last
  expect stdout line 1 contains "aaa.txt"
  expect stdout "aaa.txt" before "mmm.txt"
  expect exit 0
