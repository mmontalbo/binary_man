# ls -l: long listing format (permissions, owner, size, date, name)

file "file1.txt" "hello"
file "file2.txt" "world"
dir "subdir"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-l"
  expect stdout preserved vs "."
  expect stdout lines more than "."
  # Full long listing: perms links owner group size (4+ fields before size)
  # Uses \S+ \S+ for owner and group — distinguishes from -n (which uses \d+ \d+)
  # and from -g/-o/-G (which have only 3 fields before size)
  expect stdout every-line-matches "^(total \d+|[^ ]+ +\d+ +[a-zA-Z]\S* +[a-zA-Z]\S* +\d)"
  expect exit 0
