# ls -q: print ? instead of nongraphic characters

file "normal.txt" "hello"
file "has\ttab.txt" "tabbed"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-q"
  # Previous: 0/4 discriminating — no nongraphic chars in filenames.
  # Fixed by adding a file with a tab in its name.
  # -q replaces the tab with ?, so the output line differs.
  expect stdout contains "?"
  expect stdout lines same as "."
  expect exit 0
