# ls -u: sort by access time

file "old.txt" "old"
props "old.txt" mtime old
file "recent.txt" "recent"
props "recent.txt" mtime recent

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-u"
  # FAILED: 0/2 discriminating — lines same, no sort verification
  #   -u sorts by atime. In sandbox, atime may differ from alpha order
  #   since files are created sequentially (recent.txt accessed after old.txt).
  #   But atime behavior is filesystem-dependent (noatime mount).
  # expect stdout lines same as "."
  expect stdout lines same as "."
  # NOTE: Cannot reliably test reordering — atime depends on mount options.
  # This test remains weak by design.
  expect exit 0
