# ls -v: natural sort of version numbers within text

file "file1.txt" "one"
file "file2.txt" "two"
file "file10.txt" "ten"
file "file20.txt" "twenty"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-v"
  expect stdout reordered vs "."
  expect stdout lines same as "."
  # Alpha order: file1, file10, file2, file20 (lexicographic)
  # Version sort: file1, file2, file10, file20 (numeric)
  # file1 before file2 is true in version sort but false in alpha and reverse-alpha
  expect stdout "file1.txt" before "file2.txt"
  expect stdout "file2.txt" before "file10.txt"
  expect exit 0
