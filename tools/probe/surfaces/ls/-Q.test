# ls -Q: enclose entry names in double quotes

file "alpha.txt" "a"
file "beta.txt" "b"

test args "."
  expect stdout not-empty
  expect exit 0

test args "." "-Q"
  expect stdout preserved wrapped vs "."
  expect stdout contains "\"alpha.txt\""
  expect stdout contains "\"beta.txt\""
  expect stdout lines same as "."
  expect exit 0
