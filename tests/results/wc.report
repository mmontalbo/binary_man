# Exploration: wc

## Rounds
  round 0: 58 isolated cumulative, 40 identical in round (single-phase)

## Observed: 6/7 flags
  4 solo, 2 via combination
  1 additional error-differentiated
  robustness: 7 robust, 0 moderate, 0 fragile

Aliases: -L = --max-line-length, -c = --bytes, -l = --lines, -m = --chars, -w = --words

## Solo (unique behavior)
  --files0-from  # read input from the files specified by NUL-terminated names in file F; If F is - then read names from standard input
    exemplar: "--files0-from=1" in words_standard (different)
    base:
            0       0       0
    flag:
  --total  # when to print a line with total counts; WHEN can be: auto, always, only, never
    exemplar: "--total=always" in words_minimal (different)
    base:
            0       0       0
    flag:
            0       0       0
            0       0       0 total
  -L  # print the maximum display width
    exemplar: "-L" "input.txt" in words_minimal (reordered)
    base:
       1512  1513 10586 input.txt
    flag:
      18 input.txt
  -l  # print the newline counts
    exemplar: "-l" "input.txt" in words_minimal (reordered)
    base:
       1512  1513 10586 input.txt
    flag:
      1512 input.txt
  -w  # print the word counts
    exemplar: "-w" "input.txt" in words_minimal (reordered)
    base:
       1512  1513 10586 input.txt
    flag:
      1513 input.txt

