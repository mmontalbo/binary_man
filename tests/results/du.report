# Exploration: du

## Rounds
  round 0: 191 isolated cumulative, 144 identical in round (single-phase)

## Observed: 25/26 flags
  10 solo, 15 via combination
  1 additional error-differentiated

Aliases: -0 = --null, -B = --block-size, -D = --dereference-args, -L = --dereference, -P = --no-dereference, -S = --separate-dirs, -X = --exclude-from, -a = --all, -b = --bytes, -c = --total, -d = --max-depth, -h = --human-readable, -l = --count-links, -s = --summarize, -t = --threshold, -x = --one-file-system

## Solo (unique behavior)
  --apparent-size  # print apparent sizes rather than device usage; although
    exemplar: "--apparent-size" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      11	input.txt
      1	other.txt
  --exclude  # exclude files that match PATTERN
    exemplar: "--exclude=.*" "input.txt" "subdir" in numbers_standard / input.txt=empty (+1 lines, exit 1→0)
    base:
      0	input.txt
      8	subdir
    flag:
      0	input.txt
      8	subdir
  --files0-from  # summarize device usage of the
    exemplar: "--files0-from=f" in numbers_standard (different)
    base:
      8	./subdir
      36	.
    flag:
  --inodes  # list inode usage information instead of block usage
    exemplar: "--inodes" "input.txt" "other.txt" in numbers_standard / input.txt=empty (different)
    base:
      0	input.txt
      4	other.txt
    flag:
      1	input.txt
      1	other.txt
  --si  # like -h, but use powers of 1000 not 1024
    exemplar: "--si" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      13k	input.txt
      4.1k	other.txt
  --time  # show time as WORD instead of modification time:
    exemplar: "--time" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      12	2026-05-11 15:58	input.txt
      4	2026-05-11 15:58	other.txt
  -B  # scale sizes by SIZE before printing them; e.g.,
    exemplar: "-B" in numbers_standard (different)
    base:
      8	./subdir
      36	.
    flag:
  -X  # exclude files that match any pattern in FILE
    exemplar: "-X" "input.txt" "other.txt" in words_minimal (different)
    base:
      12	input.txt
      4	other.txt
    flag:
      4	other.txt
  -d  # print the total for a directory (or file, with --all)
    exemplar: "-d" "$(head -n1 input.txt)" "." in numbers_standard (different)
    base:
      8	./subdir
      36	.
    flag:
      36	.
  -m  # like --block-size=1M
    exemplar: "-m" "input.txt" "subdir" in words_standard (+1 lines, exit 1→0)
    base:
      12	input.txt
      8	subdir
    flag:
      1	input.txt
      1	subdir
  -t  # exclude entries smaller than SIZE if positive,
    exemplar: "-t" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      4	input.txt
    flag:
      4	input.txt

## Via combination (distinguishable when paired)
  --time-style  e.g. "-X" "--time-style=auto" "$(head -n1 input.txt)" "."
  -0  e.g. "-0" "-m" "$(head -n1 input.txt)" "."
  -D  e.g. "-B" "-D" "$(head -n1 input.txt)" "."
  -H  e.g. "-d" "-H" "$(head -n1 input.txt)" "."
  -L  e.g. "-B" "-L" "$(head -n1 input.txt)" "."
  -P  e.g. "-B" "-P" "$(head -n1 input.txt)" "."
  -S  e.g. "-d" "-S" "$(head -n1 input.txt)" "."
  -a  e.g. "-a" "-b" "$(head -n1 input.txt)" "."
  -b  e.g. "-a" "-b" "$(head -n1 input.txt)" "."
  -c  e.g. "-c" "-d" "$(head -n1 input.txt)" "."
  -h  e.g. "-h" "-t" "$(head -n1 input.txt)" "."
  -k  e.g. "-d" "-k" "$(head -n1 input.txt)" "."
  -l  e.g. "-B" "-l" "$(head -n1 input.txt)" "."
  -s  e.g. "-s" "--time" "$(head -n1 input.txt)" "."
  -x  e.g. "-B" "-x" "$(head -n1 input.txt)" "."

