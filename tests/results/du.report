# Exploration: du

## Rounds
  round 0: 93 isolated cumulative, 242 identical in round (single-phase)

## Observed: 25/26 flags
  8 solo, 17 via combination
  1 additional error-differentiated
  1 behavioral aliases detected
  robustness: 25 robust, 0 moderate, 0 fragile

Aliases: -0 = --null, -B = --block-size, -D = --dereference-args, -L = --dereference, -P = --no-dereference, -S = --separate-dirs, -X = --exclude-from, -a = --all, -b = --bytes, -c = --total, -d = --max-depth, -h = --human-readable, -l = --count-links, -s = --summarize, -t = --threshold, -x = --one-file-system

## Solo (unique behavior)
  --apparent-size  # print apparent sizes rather than device usage; although the apparent size is usually smaller, it may be larger due to holes in ('sparse') files, internal fragmentation, indirect blocks, and the like
    exemplar: "--apparent-size" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      11	input.txt
      1	other.txt
  --exclude  # exclude files that match PATTERN
    exemplar: "--exclude=.*" "input.txt" "subdir" in numbers_standard / input.txt=empty (+1 lines, exit 1→0)
    base:
      0	input.txt
      8	subdir
    flag:
      0	input.txt
      8	subdir
  --files0-from  # summarize device usage of the NUL-terminated file names specified in file F; if F is -, then read names from standard input
    exemplar: "--files0-from=1" in words_minimal (different)
    base:
      20	.
    flag:
  --inodes  # list inode usage information instead of block usage
    exemplar: "--inodes" "input.txt" "other.txt" in numbers_standard / input.txt=empty (different)
    base:
      0	input.txt
      4	other.txt
    flag:
      1	input.txt
      1	other.txt
  --si  # like -h, but use powers of 1000 not 1024
    exemplar: "--si" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      13k	input.txt
      4.1k	other.txt
  --time  # show time as WORD instead of modification time: atime, access, use, ctime or status
    exemplar: "--time" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      12	2026-05-12 22:24	input.txt
      4	2026-05-12 22:24	other.txt
  -B  # scale sizes by SIZE before printing them; e.g., '-BM' prints sizes in units of 1,048,576 bytes; see SIZE format below
    exemplar: "-B" "2" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      12	input.txt
      4	other.txt
    flag:
      6144	input.txt
      2048	other.txt
  -X  # exclude files that match any pattern in FILE
    exemplar: "-X" "input.txt" "input.txt" "subdir" in numbers_standard / input.txt=empty (+1 lines, exit 1→0)
    base:
      0	input.txt
      8	subdir
    flag:
      0	input.txt
      8	subdir
  -m  # like --block-size=1M
    exemplar: "-m" "input.txt" "subdir" in words_standard (+1 lines, exit 1→0)
    base:
      12	input.txt
      8	subdir
    flag:
      1	input.txt
      1	subdir

