# Exploration: head

## Rounds
  round 0: 4 isolated cumulative, 35 identical in round (discovery)
  round 1: 37 isolated cumulative, 23 identical in round (refinement)
  round 2: 40 isolated cumulative, 33 identical in round (refinement)
  round 3: 40 isolated cumulative, 33 identical in round (refinement)

## Observed: 7/7 flags
  4 solo, 3 via combination

Aliases: -c = --bytes, -n = --lines, -v = --verbose, -z = --zero-terminated

## Solo (unique behavior)
  -c  # print the first NUM bytes of each file;
    exemplar: "-c" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      100
      2
      30
      1
      20
            ...
  -n  # print the first NUM lines instead of the first 10;
    exemplar: "-n" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      100
      2
      30
      1
      20
            ...
  -v  # always print headers giving file names
    exemplar: "-v" in alpha_minimal (different)
    base:
    flag:
      ==> standard input <==
      cherry
      apple
      banana
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" "subdir" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      ==> input.txt <==
      100
      2
      30
      1
            ...

## Via combination (distinguishable when paired)
  --quiet  e.g. (pairwise evidence)
  --silent  e.g. "-c" "--silent" "input.txt"
  -q  e.g. (pairwise evidence)

