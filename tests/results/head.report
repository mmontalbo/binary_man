# Exploration: head

## Rounds
  round 0: 4 isolated cumulative, 35 identical in round (discovery)
  round 1: 37 isolated cumulative, 23 identical in round (refinement)
  round 2: 40 isolated cumulative, 32 identical in round (refinement)
  round 3: 40 isolated cumulative, 32 identical in round (refinement)

## Distinguished: 7/7 flags (5 observed behavior)
  5 observed behavior (2 solo, 3 via combination)
  2 error-differentiated only (2 solo, 0 via combination)

Aliases: -c = --bytes, -n = --lines, -v = --verbose, -z = --zero-terminated

## Solo (unique behavior)
  -c  # print the first NUM bytes of each file;
    exemplar: "-c" "input.txt" "subdir" in alpha_minimal (different)
    base:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...
    flag:
  -n  # print the first NUM lines instead of the first 10;
    exemplar: "-n" "input.txt" "subdir" in alpha_minimal (different)
    base:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...
    flag:
  -v  # always print headers giving file names
    exemplar: "-v" in alpha_minimal (different)
    base:
    flag:
      ==> standard input <==
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" "other.txt" in numeric_minimal (-1 lines)
    base:
      ==> input.txt <==
      100
      2
      30
      1
            ...
    flag:
      ==> input.txt <==
      100
      2
      30
      1
            ...

## Via combination (distinguishable when paired)
  --quiet  e.g. (pairwise evidence)
