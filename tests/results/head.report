# Exploration: head

## Rounds
  round 0: 18 isolated cumulative, 35 identical in round (single-phase)

## Observed: 5/7 flags
  1 solo, 4 via combination
  2 additional error-differentiated
  robustness: 7 robust, 0 moderate, 0 fragile

Aliases: -c = --bytes, -n = --lines, -v = --verbose, -z = --zero-terminated

## Solo (unique behavior)
  -v  # always print headers giving file names
    exemplar: "-v" in words_minimal (different)
    base:
    flag:
      ==> standard input <==

## Via combination (distinguishable when paired)
  --quiet  e.g. "-n" "--quiet" "$(head -n1 input.txt)" "."
  --silent  e.g. "-n" "--silent" "$(head -n1 input.txt)" "."
  -c  e.g. "-c" "-n" "$(head -n1 input.txt)" "."
  -n  e.g. "-v" "-n" "$(head -n1 input.txt)" "."
  -q  e.g. "-n" "-q" "$(head -n1 input.txt)" "."
  -z  e.g. "-c" "-z" "$(head -n1 input.txt)" "."

