# Exploration: head

## Test scope
  88 behavioral groups: 56 unique, 32 shared

  Contexts referenced below:
    words_minimal:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "hello world"
    words_standard:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "other content\nsecond line"
      write "a.txt" "first"
      write "b.txt" "second"
      write ".hidden" "secret"
      mkdir "subdir"
      write "subdir/nested.txt" "nested"
      symlink "link.txt" -> "input.txt"
      write "exec.sh" "#!/bin/sh
echo hello"
      props "exec.sh" executable
      write "readonly.dat" "protected"
      props "readonly.dat" readonly
      write "-rf" "flag-like filename"

## Observed: 7/7 flags
  4 uniquely observable, 3 distinguishable via flag pairs
  robustness: 7 verified in all contexts, 0 in most, 0 context-dependent

Aliases: -c = --bytes, -n = --lines, -v = --verbose, -z = --zero-terminated

## Verified behavior (flag produced observable output)
  -v  # always print headers giving file names
    tested: "-v" in words_minimal
    | flag adds 1 lines: ==> standard input <==
    without flag:
    with flag:
      ==> standard input <==
  -z  # line delimiter is NUL, not newline
    tested: "-z" "input.txt" in words_minimal
    | flag adds 1502 lines: across, Africa, afternoon, again, against
    | 10 lines unchanged
    without flag:
            ... (9 identical)
      acknowledge
    with flag:
            ... (9 identical)
      acknowledge
      across
      Africa
      afternoon
      again
      against
            ... (1497 more)

## Recognized but errored (flag accepted, no successful output observed)
  -c  # print the first NUM bytes of each file; with the leading '-', print all but the last NUM bytes of each file
    tested: "-c" in words_standard
    | exit: 0 → 1
    | stderr: head: option requires an argument -- 'c'
  -n  # print the first NUM lines instead of the first 10; with the leading '-', print all but the last NUM lines of each file
    tested: "-n" in words_standard
    | exit: 0 → 1
    | stderr: head: option requires an argument -- 'n'

## Distinguishable in combination (verified via flag pairs)
  --quiet
    | flag removes 3 lines: ==> input.txt <==, , ==> other.txt <==
    | 12 lines unchanged
    proven via: "-c" "--quiet" "$(head -n1 input.txt)" "."
  --silent
    | flag removes 3 lines: ==> input.txt <==, , ==> other.txt <==
    | 12 lines unchanged
    proven via: "-n" "--silent" "$(head -n1 input.txt)" "."
  -q
    | flag removes 3 lines: ==> input.txt <==, , ==> other.txt <==
    | 12 lines unchanged
    proven via: "-n" "-q" "$(head -n1 input.txt)" "."

