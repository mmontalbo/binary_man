# Exploration: head

## Rounds
  round 0: 37 isolated cumulative, 23 identical in round (discovery)
  round 1: 40 isolated cumulative, 32 identical in round (refinement)
  round 2: 40 isolated cumulative, 32 identical in round (refinement)

## Distinguished: 7/7 flags
  5 observed behavior (2 solo, 3 via combination)
  2 error-differentiated only (2 solo, 0 via combination)

Aliases: -c = --bytes, -n = --lines, -v = --verbose, -z = --zero-terminated

## Solo (unique behavior)
  -c  # print the first NUM bytes of each file;
    exemplar: "-c" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -n  # print the first NUM lines instead of the first 10;
    exemplar: "-n" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -v  # always print headers giving file names
    exemplar: "-v" "input.txt" "other.txt" in alpha_minimal (-4 lines)
    base:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...
    flag:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...
    flag:
      ==> input.txt <==
      cherry
      Apple
      banana
      Date
            ...

## Via combination (distinguishable when paired)
  --quiet  e.g. (pairwise evidence)
  --silent  e.g. "-n" "--silent" "input.txt" "other.txt"
  -q  e.g. (pairwise evidence)

