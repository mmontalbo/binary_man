# Exploration: sort

## Rounds
  round 0: 114 isolated cumulative, 148 identical in round (single-phase)

## Observed: 23/30 flags
  18 solo, 5 via combination
  7 additional error-differentiated
  1 behavioral aliases detected
  robustness: 26 robust, 0 moderate, 0 fragile

Aliases: -M = --month-sort, -R = --random-sort, -S = --buffer-size, -T = --temporary-directory, -V = --version-sort, -b = --ignore-leading-blanks, -d = --dictionary-order, -f = --ignore-case, -g = --general-numeric-sort, -h = --human-numeric-sort, -i = --ignore-nonprinting, -k = --key, -m = --merge, -n = --numeric-sort, -o = --output, -r = --reverse, -s = --stable, -t = --field-separator, -u = --unique, -z = --zero-terminated

## Solo (unique behavior)
  --batch-size  # merge at most NMERGE inputs at once; for more use temp files
  --debug  # annotate the part of the line used to sort, and warn about questionable usage to stderr
    exemplar: "--debug" "input.txt" in words_minimal (+2882 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      ______
      Alice
      _____
      Amazon
            ...
  --files0-from  # read input from the files specified by NUL-terminated names in file F; If F is - then read names from standard input
  --parallel  # change the number of sorts run concurrently to N
    exemplar: "--parallel=1" "input.txt" in formatted_minimal (-44 lines)
    base:
      
      
      
      
      		double tab indent
            ...
    flag:
      
      
      
      
      		double tab indent
            ...
  --sort  # sort according to WORD: general-numeric -g, human-numeric -h, month -M, numeric -n, random -R, version -V
    exemplar: "--sort=auto" in words_minimal / stdin (different)
    base:
      apple
      banana
      cherry
    flag:
  -C
    exemplar: "-C" in passwd_minimal / stdin (different)
    base:
      a,b,c
      d:e:f
      g h i
    flag:
  -M  # compare (unknown) < 'JAN' < ... < 'DEC'
  -R  # shuffle, but group identical keys.  See shuf(1)
    exemplar: "-R" "input.txt" in words_minimal (+1512 lines, exit 127→0)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      impact
      would
      period
      been
      well-known
            ...
  -S  # use SIZE for main memory buffer
    exemplar: "-S" "1" "input.txt" in formatted_minimal (-44 lines)
    base:
      
      
      
      
      		double tab indent
            ...
    flag:
      
      
      
      
      		double tab indent
            ...
  -V  # natural sort of (version) numbers within text
    exemplar: "-V" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
  -b  # ignore leading blanks
    exemplar: "-b" "input.txt" in formatted_minimal (-44 lines)
    base:
      
      
      
      
      		double tab indent
            ...
    flag:
      
      
      
      
      MiXeD cAsE lInE
            ...
  -d  # consider only blanks and alphanumeric characters
    exemplar: "-d" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
  -f  # fold lower case to upper case characters
    exemplar: "-f" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
  -g  # compare according to general numerical value
    exemplar: "-g" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
  -h  # compare human readable numbers (e.g., 2K 1G)
    exemplar: "-h" "input.txt" in numbers_minimal (different)
    base:
      $1.00
      +0
      +0.0
      ,
      -
            ...
    flag:
      -1E+02
      -1E02
      -1E2
      -9223372036854775808/-1
      -2147483648/-1
            ...
  -i  # consider only printable characters
    exemplar: "-i" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
  -k  # sort via a key; KEYDEF gives location and type
    exemplar: "-k" "2" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
  -m  # merge already sorted files; do not sort
    exemplar: "-m" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
  -n  # compare according to string numerical value; see manual for which strings are supported
    exemplar: "-n" "input.txt" in numbers_minimal (different)
    base:
      $1.00
      +0
      +0.0
      ,
      -
            ...
    flag:
      -9223372036854775808/-1
      -2147483648/-1
      -1
      -1#IND
      -1.00
            ...
  -o  # write result to FILE instead of standard output
    exemplar: "-o" "input.txt" in words_minimal / stdin (different)
    base:
      apple
      banana
      cherry
    flag:
  -r  # reverse the result of comparisons
    exemplar: "-r" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      zoo
      zone
      zip
      zero
      youth
            ...
  -u  # with -c, check for strict ordering; without -c, output only the first of an equal run
    exemplar: "-u" "input.txt" in formatted_minimal (-47 lines)
    base:
      
      
      
      
      		double tab indent
            ...
    flag:
      
      		double tab indent
      	 	mixed tabs and spaces
      	indented with tab
      	tab	tab	tab	tab	tab	tab	tab	tab
            ...
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" in words_minimal (+1441 lines)
    base:
      Africa
      Alice
      Amazon
      American
      Apache
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...

## Via combination (distinguishable when paired)
  --check  e.g. (pairwise evidence)
  --compress-program  e.g. "-R" "--compress-program=cat" "input.txt" "other.txt"
  --random-source  e.g. (pairwise evidence)
  -T  e.g. "-R" "-T" "." "input.txt" "other.txt"
  -c  e.g. (pairwise evidence)
  -s  e.g. "-s" "-R" "input.txt" "other.txt"
  -t  e.g. "-t" "," "-R" "input.txt" "other.txt"

