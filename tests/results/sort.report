# Exploration: sort

## Rounds
  round 0: 36 isolated cumulative, 60 identical in round (discovery)
  round 1: 113 isolated cumulative, 48 identical in round (refinement)
  round 2: 123 isolated cumulative, 36 identical in round (refinement)
  round 3: 125 isolated cumulative, 38 identical in round (refinement)

## Observed: 24/30 flags
  17 solo, 7 via combination
  6 additional error-differentiated
  1 behavioral aliases detected

Aliases: -M = --month-sort, -R = --random-sort, -S = --buffer-size, -T = --temporary-directory, -V = --version-sort, -b = --ignore-leading-blanks, -d = --dictionary-order, -f = --ignore-case, -g = --general-numeric-sort, -h = --human-numeric-sort, -i = --ignore-nonprinting, -k = --key, -m = --merge, -n = --numeric-sort, -o = --output, -r = --reverse, -s = --stable, -t = --field-separator, -u = --unique, -z = --zero-terminated

## Solo (unique behavior)
  --batch-size  # merge at most NMERGE inputs at once;
  --debug  # annotate the part of the line used to sort,
    exemplar: "--debug" "input.txt" "other.txt" in alpha_minimal (-20 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      Apple
      _____
      BANANA
      ______
      Date
            ...
  --files0-from  # read input from the files specified by
  --parallel  # change the number of sorts run concurrently to N
    exemplar: "--parallel=10" "input.txt" "other.txt" in numeric_minimal (-1 lines)
    base:
      1
      10
      100
      1000
      15
            ...
    flag:
      1
      10
      100
      1000
      15
            ...
  --sort  # sort according to WORD:
    exemplar: "--sort=auto" "input.txt" in alpha_minimal (different)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
  -C
    exemplar: "-C" "input.txt" in alpha_minimal (different)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
  -R  # shuffle, but group identical keys.  See shuf(1)
    exemplar: "-R" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      BANANA
      banana
      Date
      apple
      Apple
            ...
  -S  # use SIZE for main memory buffer
  -T  # use DIR for temporaries, not $TMPDIR or /tmp;
    exemplar: "-T" "input.txt" "other.txt" in numeric_standard (different)
    base:
      1
      10
      100
      1000
      15
            ...
    flag:
      other content
      second line
  -V  # natural sort of (version) numbers within text
    exemplar: "-V" "input.txt" "other.txt" in numeric_minimal (-1 lines)
    base:
      1
      10
      100
      1000
      15
            ...
    flag:
      1
      2
      3
      5
      7
            ...
  -b  # ignore leading blanks
    exemplar: "-b" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      
      
      
      
      	indented with tab
            ...
    flag:
      
      
      
      
      escape[31msequence
            ...
  -d  # consider only blanks and alphanumeric characters
    exemplar: "-d" "input.txt" "other.txt" in tabular_minimal (-5 lines)
    base:
      a]very long line that exceeds eighty characters in total width to exercise fold and fmt and similar line-wrapping tools properly
      alice	30	new york
      alice	30	new york
      alice	30	new york
      bob	25	san francisco
            ...
    flag:
      alice	30	new york
      alice	30	new york
      alice	30	new york
      a]very long line that exceeds eighty characters in total width to exercise fold and fmt and similar line-wrapping tools properly
      bob	25	san francisco
            ...
  -f  # fold lower case to upper case characters
    exemplar: "-f" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      Apple
      apple
      BANANA
      banana
      cherry
            ...
  -i  # consider only printable characters
    exemplar: "-i" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      
      
      
      
      	indented with tab
            ...
    flag:
      
      
      
      
        leading spaces
            ...
  -k  # sort via a key; KEYDEF gives location and type
  -m  # merge already sorted files; do not sort
    exemplar: "-m" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -o  # write result to FILE instead of standard output
    exemplar: "-o" "input.txt" in alpha_minimal (different)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
  -r  # reverse the result of comparisons
    exemplar: "-r" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      hello world
      elderberry
      cherry
      banana
      apple
            ...
  -t  # use SEP instead of non-blank to blank transition
  -u  # with -c, check for strict ordering;
    exemplar: "-u" "input.txt" in formatted_minimal (-6 lines)
    base:
      
      
      
      
      	indented with tab
            ...
    flag:
      
      	indented with tab
      	two	tabs
        leading spaces
      escape[31msequence
            ...
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" in alpha_minimal (-9 lines)
    base:
      Apple
      BANANA
      Date
      apple
      banana
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...

## Via combination (distinguishable when paired)
  --check  e.g. "--output=input.txt" "--check" "input.txt"
  --compress-program  e.g. "-o" "--compress-program"
  --random-source  e.g. "--output=input.txt" "--random-source" "input.txt"
  -M  e.g. "-i" "-M"
  -c  e.g. "-R" "-c" "input.txt"
  -g  e.g. "-g" "-h"
  -h  e.g. "-M" "-h"
  -n  e.g. "-d" "-n"
  -s  e.g. "--output=input.txt" "-M" "-s"

