# Exploration: xargs

## Rounds
  round 0: 62 isolated cumulative, 77 identical in round (single-phase)

## Observed: 18/21 flags
  7 solo, 11 via combination
  2 additional error-differentiated
  robustness: 17 robust, 0 moderate, 0 fragile

Aliases: -0 = --null, -L = --max-lines, -P = --max-procs, -a = --arg-file, -d = --delimiter, -n = --max-args, -o = --open-tty, -p = --interactive, -r = --no-run-if-empty, -s = --max-chars, -t = --verbose, -x = --exit

## Solo (unique behavior)
  --show-limits  # show limits on command-line length
    exemplar: "--show-limits" in words_minimal / stdin (reordered)
    base:
      cherry apple banana
    flag:
      cherry apple banana
  -L  # use at most MAX-LINES non-blank input lines per command line
    exemplar: "-L" "2" "echo" "input.txt" in passwd_minimal / stdin (+1 lines)
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h i
  -a  # read arguments from FILE, not standard input
    exemplar: "-a" "other.txt" "echo" "input.txt" in words_minimal (different)
    base:
      input.txt
    flag:
      input.txt hello world
  -n  # use at most MAX-ARGS arguments per command line
    exemplar: "-n" "2" "echo" "input.txt" in passwd_minimal / stdin (+2 lines)
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h
      input.txt i
  -o  # Reopen stdin as /dev/tty in the child process before executing the command; useful to run an interactive application.
  -r  # if there are no arguments, then do not run COMMAND; if this option is not given, COMMAND will be run at least once
    exemplar: "-r" in words_minimal / stdin (+1 lines)
    base:
      cherry apple banana
    flag:
      cherry apple banana
  -s  # limit length of command line to MAX-CHARS
    exemplar: "-s" "100" "echo" in words_minimal / stdin (reordered)
    base:
      cherry apple banana
    flag:
      cherry apple banana
  -t  # print commands before executing them
    exemplar: "-t" in words_minimal / stdin (reordered)
    base:
      cherry apple banana
    flag:
      cherry apple banana

## Via combination (distinguishable when paired)
  --eof  e.g. "--eof" "-o" "echo" "input.txt"
  --process-slot-var  e.g. "--process-slot-var=test" "-o" "echo" "input.txt"
  --replace  e.g. (pairwise evidence)
  -0  e.g. (pairwise evidence)
  -E  e.g. "-o" "-E" "EOF" "echo" "input.txt"
  -P  e.g. (pairwise evidence)
  -d  e.g. "-d" "," "-o" "echo" "input.txt"
  -e  e.g. "-o" "-e" "echo" "input.txt"
  -i  e.g. "-o" "-i" "echo" "input.txt"
  -l  e.g. "-o" "-l" "echo" "input.txt"
  -p  e.g. (pairwise evidence)
  -x  e.g. (pairwise evidence)

