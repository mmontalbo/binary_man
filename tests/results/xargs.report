# Exploration: xargs

## Rounds
  round 0: 58 isolated cumulative, 87 identical in round (single-phase)

## Observed: 16/21 flags
  7 solo, 9 via combination
  2 additional error-differentiated
  robustness: 17 robust, 0 moderate, 0 fragile

Aliases: -0 = --null, -L = --max-lines, -P = --max-procs, -a = --arg-file, -d = --delimiter, -n = --max-args, -o = --open-tty, -p = --interactive, -r = --no-run-if-empty, -s = --max-chars, -t = --verbose, -x = --exit

## Solo (unique behavior)
  --show-limits  # show limits on command-line length
    exemplar: "--show-limits" "echo" "input.txt" in words_standard (different)
    base:
      input.txt
    flag:
      input.txt
  -L  # use at most MAX-LINES non-blank input lines per command line
    exemplar: "-L" "2" "echo" "input.txt" in passwd_minimal / stdin (+1 lines)
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h i
  -a  # read arguments from FILE, not standard input
    exemplar: "-a" "input.txt" "echo" "input.txt" in words_standard (reordered)
    base:
      input.txt
    flag:
      input.txt aardvark abbreviation about abstract accept accepted accepting access accommodate acknowledge across Africa afternoon again against aggregate ahead algorithm Alice all already also although always Amazon American among an and another answer Apache apostrophe Apple application approximately architect Argentina around arrange Asia assembly at Australia available awkward azure back balance banana bandwidth Barcelona be because been before beginning Beijing believe bell-tower below benchmark beneath Berlin best between beyond bicycle billion binary birthday black blue Bob Boolean both boundary breakfast bridge brilliant brother-in-law Budapest buffalo build business but by café California came can Canada cannot
  -n  # use at most MAX-ARGS arguments per command line
    exemplar: "-n" "2" "echo" "input.txt" in passwd_minimal / stdin (+2 lines)
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h
      input.txt i
  -o  # Reopen stdin as /dev/tty in the child process before executing the command; useful to run an interactive application.
  -r  # if there are no arguments, then do not run COMMAND; if this option is not given, COMMAND will be run at least once
    exemplar: "-r" in words_minimal / stdin (+1 lines)
    base:
      cherry apple banana
    flag:
      cherry apple banana
  -s  # limit length of command line to MAX-CHARS
    exemplar: "-s" "100" "echo" "input.txt" in words_standard (different)
    base:
      input.txt
    flag:
      input.txt
  -t  # print commands before executing them
    exemplar: "-t" "echo" "input.txt" in words_standard (different)
    base:
      input.txt
    flag:
      input.txt

