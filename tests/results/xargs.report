# Exploration: xargs

## Rounds
  round 0: 7 isolated cumulative, 22 identical in round (discovery)
  round 1: 30 isolated cumulative, 8 identical in round (refinement)
  round 2: 31 isolated cumulative, 8 identical in round (refinement)
  round 3: 31 isolated cumulative, 8 identical in round (refinement)

## Observed: 14/21 flags
  7 solo, 7 via combination
  7 additional error-differentiated
  1 behavioral aliases detected

Aliases: -0 = --null, -L = --max-lines, -P = --max-procs, -a = --arg-file, -d = --delimiter, -n = --max-args, -o = --open-tty, -p = --interactive, -r = --no-run-if-empty, -s = --max-chars, -t = --verbose, -x = --exit

## Solo (unique behavior)
  --show-limits  # show limits on command-line length
    exemplar: "--show-limits" in alpha_minimal (different)
    base:
    flag:
      cherry apple banana
  -E
    exemplar: "-E" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -I
    exemplar: "-I" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -L  # use at most MAX-LINES non-blank input lines per
    exemplar: "-L" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -P  # run at most MAX-PROCS processes at a time
    exemplar: "-P" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -a  # read arguments from FILE, not standard input
    exemplar: "-a" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -d  # items in input stream are separated by CHARACTER,
    exemplar: "-d" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -n  # use at most MAX-ARGS arguments per command line
    exemplar: "-n" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -o  # Reopen stdin as /dev/tty in the child process
  -p  # prompt before running commands
    exemplar: "-p" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -s  # limit length of command line to MAX-CHARS
    exemplar: "-s" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -t  # print commands before executing them
    exemplar: "-t" in alpha_minimal (different)
    base:
    flag:
      cherry apple banana

