# Exploration: xargs

## Rounds
  round 0: 65 isolated cumulative, 104 identical in round (single-phase)

## Observed: 19/21 flags
  7 solo, 12 via combination
  2 additional error-differentiated
  robustness: 23 robust, 0 moderate, 0 fragile

Aliases: -0 = --null, -L = --max-lines, -P = --max-procs, -a = --arg-file, -d = --delimiter, -n = --max-args, -o = --open-tty, -p = --interactive, -r = --no-run-if-empty, -s = --max-chars, -t = --verbose, -x = --exit

## Solo (unique behavior)
  --show-limits  # show limits on command-line length
    exemplar: "--show-limits" in words_minimal / stdin
    | stderr: Your environment variables take up 23044 bytes
    base:
      cherry apple banana
    flag:
      cherry apple banana
  -L  # use at most MAX-LINES non-blank input lines per command line
    exemplar: "-L" "2" "echo" "input.txt" in passwd_minimal / stdin
    | 2 only in this: input.txt a,b,c d:e:f, input.txt g h i
    | 1 only in ref: input.txt a,b,c d:e:f g h i
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h i
  -a  # read arguments from FILE, not standard input
    exemplar: "--arg-file=other.txt" "echo" "input.txt" in words_minimal
    | 1 only in this: input.txt hello world
    | 1 only in ref: input.txt
    base:
      input.txt
    flag:
      input.txt hello world
  -n  # use at most MAX-ARGS arguments per command line
    exemplar: "--max-args=2" "echo" "input.txt" in passwd_minimal / stdin
    | 3 only in this: input.txt a,b,c d:e:f, input.txt g h, input.txt i
    | 1 only in ref: input.txt a,b,c d:e:f g h i
    base:
      input.txt a,b,c d:e:f g h i
    flag:
      input.txt a,b,c d:e:f
      input.txt g h
      input.txt i
  -o  # Reopen stdin as /dev/tty in the child process before executing the command; useful to run an interactive application.
    exemplar: "-o" in passwd_standard
    | 1 only in ref: 
    | exit: 0 → 125
    | stderr: xargs: '/dev/tty': No such device or address
  -r  # if there are no arguments, then do not run COMMAND; if this option is not given, COMMAND will be run at least once
    exemplar: "-r" in passwd_standard
    | 1 only in ref: 
  -s  # limit length of command line to MAX-CHARS
    exemplar: "-s" "1" in passwd_standard
    | 1 only in ref: 
    | exit: 0 → 1
    | stderr: xargs: option requires an argument -- 's'
  -t  # print commands before executing them
    exemplar: "-t" in words_minimal / stdin
    | stderr: /nix/store/n9gh8gxx5xx51ihgll2l20ar9b2vmgzy-coreutils-9.5/bin/echo cherry apple banana
    base:
      cherry apple banana
    flag:
      cherry apple banana

