# Exploration: xargs

## Rounds
  round 0: 11 isolated cumulative, 42 identical in round (single-phase)

## Observed: 14/21 flags
  3 solo, 11 via combination
  4 additional error-differentiated
  robustness: 17 robust, 0 moderate, 0 fragile

Aliases: -0 = --null, -L = --max-lines, -P = --max-procs, -a = --arg-file, -d = --delimiter, -n = --max-args, -o = --open-tty, -p = --interactive, -r = --no-run-if-empty, -s = --max-chars, -t = --verbose, -x = --exit

## Solo (unique behavior)
  -L  # use at most MAX-LINES non-blank input lines per command line
    exemplar: "-L" "1" in passwd_minimal / stdin (different)
    base:
      a,b,c d:e:f g h i
    flag:
  -a  # read arguments from FILE, not standard input
    exemplar: "-a" "other.txt" in words_minimal (different)
    base:
    flag:
      hello world
  -n  # use at most MAX-ARGS arguments per command line
    exemplar: "-n" "1" in passwd_minimal / stdin (different)
    base:
      a,b,c d:e:f g h i
    flag:

