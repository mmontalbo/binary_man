# Exploration: rm

## Rounds
  round 0: 11 isolated cumulative, 11 identical in round (single-phase)

## Observed: 12/12 flags
  2 solo, 10 via combination
  1 behavioral aliases detected
  robustness: 12 robust, 0 moderate, 0 fragile

Aliases: -d = --dir, -f = --force, -v = --verbose

## Solo (unique behavior)
  -f  # ignore nonexistent files and arguments, never prompt
    exemplar: "-f" "input.txt" in empty_dir
    | exit: 1 → 0
    | stderr removed
  -v  # explain what is being done
    exemplar: "-v" "input.txt" in words_minimal
    | 1 only in this: removed 'input.txt'
    base:
    flag:
      removed 'input.txt'

## Via combination (distinguishable when paired)
  --interactive
    | stderr: rm: remove regular file 'input.txt'?
    | fs: did not delete input.txt
    evidence: (pairwise evidence)
  --no-preserve-root  # do not treat '/' specially
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  --one-file-system  # when removing a hierarchy recursively, skip any directory that is on a file system different from that of the corresponding command line argument
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  --preserve-root
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  --recursive
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  -I  # prompt once before removing more than three files, or when removing recursively; less intrusive than -i, while still giving protection against most mistakes
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  -R
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  -d  # remove empty directories
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)
  -i  # prompt before every removal
    | stderr: rm: remove regular file 'input.txt'?
    | fs: did not delete input.txt
    evidence: (pairwise evidence)
  -r
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    evidence: (pairwise evidence)

