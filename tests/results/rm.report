# Exploration: rm

## Test scope
  22 behavioral groups: 11 unique, 11 shared

  Contexts referenced below:
    empty_dir:
      (empty directory)
    words_deep:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "deep other\nline two\nline three"
      mkdir "level1"
      mkdir "level1/level2"
      write "level1/a.txt" "depth one"
      write "level1/level2/b.txt" "depth two"
      symlink "link_to_dir" -> "level1"
      write "old.txt" "ancient"
      props "old.txt" mtime old
      write "big.bin" "<generated 10000 bytes>"
    words_minimal:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "hello world"
    words_standard:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "other content\nsecond line"
      write "a.txt" "first"
      write "b.txt" "second"
      write ".hidden" "secret"
      mkdir "subdir"
      write "subdir/nested.txt" "nested"
      symlink "link.txt" -> "input.txt"
      write "exec.sh" "#!/bin/sh
echo hello"
      props "exec.sh" executable
      write "readonly.dat" "protected"
      props "readonly.dat" readonly
      write "-rf" "flag-like filename"

## Observed: 12/12 flags
  2 uniquely observable, 10 distinguishable via flag pairs
  1 behavioral aliases (different flags, identical behavior)
  robustness: 12 verified in all contexts, 0 in most, 0 context-dependent

Aliases: -d = --dir, -f = --force, -v = --verbose

## Unique behavior (observable when tested alone)
  -f  # ignore nonexistent files and arguments, never prompt
    tested: "-f" "input.txt" in empty_dir
    | exit: 1 → 0
    | stderr removed
  -v  # explain what is being done
    tested: "-v" "input.txt" in words_minimal
    | flag adds 1 lines: removed 'input.txt'
    without flag:
    with flag:
      removed 'input.txt'

## Distinguishable in combination (verified via flag pairs)
  --interactive
    | stderr: rm: remove regular file 'input.txt'?
    | fs: did not delete input.txt
    proven via: (pairwise evidence)
  --no-preserve-root  # do not treat '/' specially
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  --one-file-system  # when removing a hierarchy recursively, skip any directory that is on a file system different from that of the corresponding command line
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  --preserve-root
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  --recursive
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  -I  # prompt once before removing more than three files, or when removing recursively; less intrusive than -i, while still giving protection
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  -R
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  -d  # remove empty directories
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)
  -i  # prompt before every removal
    | stderr: rm: remove regular file 'input.txt'?
    | fs: did not delete input.txt
    proven via: (pairwise evidence)
  -r
    | stderr: rm: remove regular file 'input.txt'? rm: remove regular file 'other.txt'?
    | fs: did not delete input.txt
    | fs: did not delete other.txt
    proven via: (pairwise evidence)

