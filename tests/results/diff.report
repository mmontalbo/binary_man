# Exploration: diff

## Rounds
  round 0: 290 isolated cumulative, 50 identical in round (single-phase)

## Observed: 51/53 flags
  20 solo, 31 via combination
  3 additional error-differentiated
  robustness: 51 robust, 0 moderate, 0 fragile

Aliases: -B = --ignore-blank-lines, -D = --ifdef, -E = --ignore-tab-expansion, -F = --show-function-line, -I = --ignore-matching-lines, -N = --new-file, -S = --starting-file, -T = --initial-tab, -W = --width, -X = --exclude-from, -Z = --ignore-trailing-space, -a = --text, -b = --ignore-space-change, -d = --minimal, -e = --ed, -i = --ignore-case, -l = --paginate, -n = --rcs, -p = --show-c-function, -q = --brief, -r = --recursive, -s = --report-identical-files, -t = --expand-tabs, -w = --ignore-all-space, -x = --exclude, -y = --side-by-side

## Solo (unique behavior)
  --GTYPE-group-format  # format GTYPE input groups with GFMT
  --LTYPE-line-format  # format LTYPE input lines with LFMT
  --from-file  # compare FILE1 to all operands; FILE1 can be a directory
    exemplar: "--from-file=/dev/null" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      0a1,1512
      > aardvark
      > abbreviation
      > about
      > abstract
            ...
  --line-format  # format all input lines with LFMT
    exemplar: "--line-format=1" "input.txt" "other.txt" in words_standard (reordered)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      
  --suppress-blank-empty  # suppress space or tab before empty output lines
    exemplar: "--suppress-blank-empty" "input.txt" "other.txt" in formatted_standard (-44 lines)
    base:
      1,27c1,2
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
    flag:
      1,27c1,2
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
  --tabsize  # tab stops every NUM (default 8) print columns
    exemplar: "--tabsize=1" "input.txt" "other.txt" in paths_minimal (-30 lines)
    base:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
    flag:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
  --to-file  # compare all operands to FILE2; FILE2 can be a directory
    exemplar: "--to-file=/dev/null" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      1,1512d0
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
  --unified
    exemplar: "--unified" "input.txt" "other.txt" in words_minimal (+1516 lines, exit 127→1)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      --- input.txt	2026-05-13 23:23:58.110578433 -0700
      +++ other.txt	2026-05-13 23:23:58.110611265 -0700
      @@ -1,1512 +1 @@
      -aardvark
      -abbreviation
            ...
  -D  # output merged file with '#ifdef NAME' diffs
    exemplar: "-D" "test" "input.txt" "other.txt" in words_standard (+1441 lines)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      #ifndef test
      aardvark
      abbreviation
      about
      abstract
            ...
  -I  # ignore changes where all lines match RE
    exemplar: "-I" "." "input.txt" "other.txt" in words_standard (different)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
  -T  # make tabs line up by prepending a tab
    exemplar: "-T" "input.txt" "other.txt" in words_standard (+1441 lines)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      1,1512c1,2
      <	aardvark
      <	abbreviation
      <	about
      <	abstract
            ...
  -U
    exemplar: "-U" "1" "input.txt" "other.txt" in words_minimal (+1516 lines, exit 127→1)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      --- input.txt	2026-05-13 23:23:58.110407189 -0700
      +++ other.txt	2026-05-13 23:23:58.110465129 -0700
      @@ -1,1512 +1 @@
      -aardvark
      -abbreviation
            ...
  -W  # output at most NUM (default 130) print columns
    exemplar: "-W" "1" "input.txt" "other.txt" in paths_minimal (-30 lines)
    base:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
    flag:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
  -X  # exclude files that match any pattern in FILE
    exemplar: "-X" "input.txt" "input.txt" "other.txt" in paths_minimal (-30 lines)
    base:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
    flag:
      1,42c1
      < /usr/local/bin/python3
      < /usr/bin/env
      < /bin/sh
      < /home/alice/.bashrc
            ...
  -e  # output an ed script
    exemplar: "-e" "input.txt" "other.txt" in words_standard (reordered)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      1,1512c
      other content
      second line
      .
  -l  # pass output through 'pr' to paginate it
    exemplar: "-l" "input.txt" "other.txt" in words_minimal (+1716 lines)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      
      
      2026-05-13 23:23           diff -l input.txt other.txt            Page 1
      
      
            ...
  -n  # output an RCS format diff
    exemplar: "-n" "input.txt" "other.txt" in words_standard (reordered)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      d1 1512
      a1512 2
      other content
      second line
  -q  # report only when files differ
    exemplar: "-q" "input.txt" "other.txt" in words_standard (different)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      Files input.txt and other.txt differ
  -t  # expand tabs to spaces in output
    exemplar: "-t" "input.txt" "other.txt" in formatted_standard (-44 lines)
    base:
      1,27c1,2
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
    flag:
      1,27c1,2
      < first line
      < second line with trailing spaces
      <         indented with tab
      <     indented with spaces
            ...
  -u
    exemplar: "-u" "input.txt" "other.txt" in words_minimal (+1516 lines, exit 127→1)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      --- input.txt	2026-05-13 23:23:58.110293154 -0700
      +++ other.txt	2026-05-13 23:23:58.110320506 -0700
      @@ -1,1512 +1 @@
      -aardvark
      -abbreviation
            ...
  -v  # output version information and exit
    exemplar: "-v" "input.txt" "other.txt" in words_standard (different)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
