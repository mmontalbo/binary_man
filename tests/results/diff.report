# Exploration: diff

## Rounds
  round 0: 264 isolated cumulative, 68 identical in round (single-phase)

## Observed: 51/53 flags
  11 solo, 40 via combination
  3 additional error-differentiated
  robustness: 51 robust, 0 moderate, 0 fragile

Aliases: -B = --ignore-blank-lines, -D = --ifdef, -E = --ignore-tab-expansion, -F = --show-function-line, -I = --ignore-matching-lines, -N = --new-file, -S = --starting-file, -T = --initial-tab, -W = --width, -X = --exclude-from, -Z = --ignore-trailing-space, -a = --text, -b = --ignore-space-change, -d = --minimal, -e = --ed, -i = --ignore-case, -l = --paginate, -n = --rcs, -p = --show-c-function, -q = --brief, -r = --recursive, -s = --report-identical-files, -t = --expand-tabs, -w = --ignore-all-space, -x = --exclude, -y = --side-by-side

## Solo (unique behavior)
  --from-file  # compare FILE1 to all operands; FILE1 can be a directory
    exemplar: "--from-file=/dev/null" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      0a1,1512
      > aardvark
      > abbreviation
      > about
      > abstract
            ...
  --line-format  # format all input lines with LFMT
    exemplar: "--line-format=auto" "input.txt" "other.txt" in words_minimal (reordered)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      
  --tabsize  # tab stops every NUM (default 8) print columns
    exemplar: "--tabsize=1" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
      1,27c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
    flag:
      1,27c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
  --to-file  # compare all operands to FILE2; FILE2 can be a directory
    exemplar: "--to-file=/dev/null" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
      1,1512c1
