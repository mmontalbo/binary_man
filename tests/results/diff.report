            ...
  -D  # output merged file with '#ifdef NAME' diffs
    exemplar: "-D" "x" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      #ifndef x
      aardvark
      abbreviation
      about
      abstract
            ...
  -I  # ignore changes where all lines match RE
    exemplar: "-I" "." "input.txt" "other.txt" in numbers_minimal (different)
    base:
      1,71c1
      < 0
      < 1
      < 1.00
      < $1.00
            ...
    flag:
