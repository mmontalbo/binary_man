            ...
  -y  # output in two columns
    exemplar: "-y" "input.txt" "other.txt" in words_standard (+1441 lines)
    base:
      1,1512c1,2
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      aardvark						      |	other content
      abbreviation						      |	second line
      about							      <
      abstract						      <
      accept							      <
            ...

## Via combination (distinguishable when paired)
  --color  e.g. "--color" "-u" "input.txt" "other.txt"
  --context  e.g. (pairwise evidence)
  --horizon-lines  e.g. "-u" "--horizon-lines=1" "input.txt" "other.txt"
  --ignore-file-name-case  e.g. "--ignore-file-name-case" "-u" "input.txt" "other.txt"
  --label  e.g. "--label=test" "-U" "1" "input.txt" "other.txt"
  --left-column  e.g. "--left-column" "-U" "1" "input.txt" "other.txt"
  --no-dereference  e.g. "--no-dereference" "-u" "input.txt" "other.txt"
  --no-ignore-file-name-case  e.g. "--no-ignore-file-name-case" "-U" "1" "input.txt" "other.txt"
  --normal  e.g. (pairwise evidence)
  --palette  e.g. "--palette=1" "-U" "1" "input.txt" "other.txt"
  --speed-large-files  e.g. "--speed-large-files" "-u" "input.txt" "other.txt"
  --strip-trailing-cr  e.g. "--unified" "--strip-trailing-cr" "input.txt" "other.txt"
  --suppress-common-lines  e.g. "-U" "1" "--suppress-common-lines" "input.txt" "other.txt"
  --unidirectional-new-file  e.g. "--unified" "--unidirectional-new-file" "input.txt" "other.txt"
  -1  e.g. "-W" "-1" "input.txt" "other.txt"
  -B  e.g. "-B" "-u" "input.txt" "other.txt"
  -C  e.g. (pairwise evidence)
  -E  e.g. "-U" "1" "-E" "input.txt" "other.txt"
  -F  e.g. "-U" "1" "-F" "1" "input.txt" "other.txt"
  -N  e.g. "-U" "1" "-N" "input.txt" "other.txt"
  -S  e.g. "-S" "input.txt" "-u" "input.txt" "other.txt"
  -Z  e.g. "-Z" "--unified" "input.txt" "other.txt"
  -a  e.g. "-a" "-u" "input.txt" "other.txt"
  -b  e.g. "-b" "-u" "input.txt" "other.txt"
  -c  e.g. (pairwise evidence)
  -d  e.g. "--unified" "-d" "input.txt" "other.txt"
  -i  e.g. "-u" "-i" "input.txt" "other.txt"
  -p  e.g. "--unified" "-p" "input.txt" "other.txt"
  -r  e.g. "-r" "-u" "input.txt" "other.txt"
  -s  e.g. "-u" "-s" "input.txt" "other.txt"
  -w  e.g. "-U" "1" "-w" "input.txt" "other.txt"
  -x  e.g. "--unified" "-x" ".*" "input.txt" "other.txt"

