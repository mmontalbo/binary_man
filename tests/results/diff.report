# Exploration: diff

## Rounds
  round 0: 198 isolated cumulative, 73 identical in round (single-phase)

## Observed: 49/53 flags
  7 solo, 42 via combination
  4 additional error-differentiated

Aliases: -B = --ignore-blank-lines, -D = --ifdef, -E = --ignore-tab-expansion, -F = --show-function-line, -I = --ignore-matching-lines, -N = --new-file, -S = --starting-file, -T = --initial-tab, -W = --width, -X = --exclude-from, -Z = --ignore-trailing-space, -a = --text, -b = --ignore-space-change, -d = --minimal, -e = --ed, -i = --ignore-case, -l = --paginate, -n = --rcs, -p = --show-c-function, -q = --brief, -r = --recursive, -s = --report-identical-files, -t = --expand-tabs, -w = --ignore-all-space, -x = --exclude, -y = --side-by-side

## Solo (unique behavior)
  --horizon-lines  # keep NUM lines of the common prefix and suffix
    exemplar: "--horizon-lines=1" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      1,13c1
      < first line
      < 
      < 
      < 	indented with tab
            ...
    flag:
      1,13c1
      < first line
      < 
      < 
      < 	indented with tab
            ...
  --tabsize  # tab stops every NUM (default 8) print columns
    exemplar: "--tabsize=1" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      1,13c1
      < first line
      < 
      < 
      < 	indented with tab
            ...
    flag:
      1,13c1
      < first line
      < 
      < 
      < 	indented with tab
            ...
  --unified
    exemplar: "--unified" "input.txt" "other.txt" in alpha_minimal (+11 lines, exit 127→1)
    base:
      1,7c1
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
      --- input.txt	2026-05-11 15:24:27.750588105 -0700
      +++ other.txt	2026-05-11 15:24:27.750601410 -0700
      @@ -1,7 +1 @@
      -cherry
      -Apple
            ...
  -D  # output merged file with '#ifdef NAME' diffs
  -W  # output at most NUM (default 130) print columns
  -X  # exclude files that match any pattern in FILE
  -u
    exemplar: "-u" "input.txt" "other.txt" in alpha_minimal (+11 lines, exit 127→1)
    base:
      1,7c1
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
      --- input.txt	2026-05-11 15:24:27.749676631 -0700
      +++ other.txt	2026-05-11 15:24:27.749682322 -0700
      @@ -1,7 +1 @@
      -cherry
      -Apple
            ...

## Via combination (distinguishable when paired)
  --GTYPE-group-format  e.g. "-W" "--GTYPE-group-format=gfmt" "input.txt" "other.txt"
  --LTYPE-line-format  e.g. "-W" "--LTYPE-line-format=lfmt" "input.txt" "other.txt"
  --color  e.g. "-u" "--color" "input.txt" "other.txt"
  --context  e.g. "-X" "--context" "input.txt" "other.txt"
  --from-file  e.g. "--unified" "--from-file=input.txt" "input.txt" "other.txt"
  --ignore-file-name-case  e.g. "-X" "--ignore-file-name-case" "input.txt" "other.txt"
  --label  e.g. "-X" "--label=test" "input.txt" "other.txt"
