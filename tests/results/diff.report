      1,13c1
      < first line
      < 
      < 
      < 	indented with tab
            ...
  --line-format  # format all input lines with LFMT
    exemplar: "--line-format=lfmt" "input.txt" "other.txt" in alpha_minimal (reordered)
    base:
      1,7c1
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
      lfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmt
  --suppress-blank-empty  # suppress space or tab before empty output lines
