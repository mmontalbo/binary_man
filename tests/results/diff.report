# Exploration: diff

## Rounds
  round 0: 31 isolated cumulative, 11 identical in round (discovery)
  round 1: 51 isolated cumulative, 18 identical in round (refinement)
  round 2: 60 isolated cumulative, 26 identical in round (refinement)
  round 3: 76 isolated cumulative, 32 identical in round (refinement)

## Observed: 36/53 flags
  19 solo, 17 via combination
  2 additional error-differentiated
  2 behavioral aliases detected
  15 indistinguishable under tested conditions

Aliases: -B = --ignore-blank-lines, -D = --ifdef, -E = --ignore-tab-expansion, -F = --show-function-line, -I = --ignore-matching-lines, -N = --new-file, -S = --starting-file, -T = --initial-tab, -W = --width, -X = --exclude-from, -Z = --ignore-trailing-space, -a = --text, -b = --ignore-space-change, -d = --minimal, -e = --ed, -i = --ignore-case, -l = --paginate, -n = --rcs, -p = --show-c-function, -q = --brief, -r = --recursive, -s = --report-identical-files, -t = --expand-tabs, -w = --ignore-all-space, -x = --exclude, -y = --side-by-side

## Solo (unique behavior)
  --GTYPE-group-format  # format GTYPE input groups with GFMT
  --LTYPE-line-format  # format LTYPE input lines with LFMT
  --horizon-lines  # keep NUM lines of the common prefix and suffix
    exemplar: "--horizon-lines=1" "input.txt" "other.txt" in alpha_standard / content_crlf (+16 lines, exit 0→1)
    base:
      1,7c1,7
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
      1,7c1,7
      < cherry
      < Apple
      < banana
      < Date
            ...
  --label
    exemplar: "--label=test" "input.txt" "other.txt" in alpha_standard / content_binary_inject (+1 lines, exit 0→1)
    base:
      Binary files input.txt and other.txt differ
    flag:
      Binary files test and other.txt differ
  --line-format  # format all input lines with LFMT
    exemplar: "--line-format=lfmt" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      lfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmtlfmt
  --strip-trailing-cr  # strip trailing carriage return on input
    exemplar: "--strip-trailing-cr" "input.txt" "other.txt" in alpha_standard / content_crlf (different)
    base:
      1,7c1,7
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
  --suppress-blank-empty  # suppress space or tab before empty output lines
    exemplar: "--suppress-blank-empty" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      (no base)
    flag:
      1,13c1
      < first line
      <
      <
      < 	indented with tab
            ...
  --tabsize  # tab stops every NUM (default 8) print columns
    exemplar: "--tabsize=1" "input.txt" "other.txt" in alpha_standard / content_crlf (+16 lines, exit 0→1)
    base:
      1,7c1,7
      < cherry
      < Apple
      < banana
      < Date
            ...
    flag:
      1,7c1,7
      < cherry
      < Apple
      < banana
      < Date
            ...
  --to-file  # compare all operands to FILE2;
    exemplar: "--to-file=input.txt" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      1,2c1,16
      < other content
      < second line
      ---
      > 100
            ...
  --unified
    exemplar: "--unified" "input.txt" "other.txt" in alpha_minimal (+11 lines, exit 127→1)
    base:
      (no base)
    flag:
      --- input.txt	2026-05-10 11:08:27.807578659 -0700
      +++ other.txt	2026-05-10 11:08:27.807587776 -0700
      @@ -1,7 +1 @@
      -cherry
      -Apple
            ...
  -D  # output merged file with '#ifdef NAME' diffs
  -T  # make tabs line up by prepending a tab
    exemplar: "-T" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      1,16c1,2
      <	100
      <	2
      <	30
      <	1
            ...
  -W  # output at most NUM (default 130) print columns
  -e  # output an ed script
    exemplar: "-e" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      1,16c
      other content
      second line
      .
  -l  # pass output through 'pr' to paginate it
    exemplar: "-l" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      
      
      2026-05-10 11:08           diff -l input.txt other.txt            Page 1
      
      
            ...
  -n  # output an RCS format diff
    exemplar: "-n" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      d1 16
      a16 2
      other content
      second line
  -q  # report only when files differ
    exemplar: "-q" "input.txt" "other.txt" in many_files /input.txt=size:1 (different)
    base:
      (no base)
    flag:
      Files input.txt and other.txt differ
  -t  # expand tabs to spaces in output
    exemplar: "-t" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      (no base)
    flag:
      1,13c1
      < first line
      < 
      < 
      <         indented with tab
            ...
  -u
    exemplar: "-u" "input.txt" "other.txt" in alpha_minimal (+11 lines, exit 127→1)
    base:
      (no base)
    flag:
      --- input.txt	2026-05-10 11:08:27.806162225 -0700
      +++ other.txt	2026-05-10 11:08:27.806170401 -0700
      @@ -1,7 +1 @@
      -cherry
      -Apple
            ...
  -v  # output version information and exit
    exemplar: "-v" "input.txt" "other.txt" in many_files /input.txt=size:1 (different)
    base:
      (no base)
    flag:
      diff (GNU diffutils) 3.10
      Copyright (C) 2023 Free Software Foundation, Inc.
      License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
      This is free software: you are free to change and redistribute it.
      There is NO WARRANTY, to the extent permitted by law.
            ...
  -y  # output in two columns
    exemplar: "-y" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      100							      |	other content
      2							      |	second line
      30							      <
      1							      <
      20							      <
            ...

## Via combination (distinguishable when paired)
  --color  e.g. "--unified" "--color" "input.txt" "other.txt"
  --context  e.g. "--suppress-blank-empty" "--context" "input.txt" "other.txt"
  --from-file  e.g. "-u" "--from-file" "input.txt" "other.txt"
  --ignore-file-name-case  e.g. "-u" "--ignore-file-name-case" "--left-column" "--unidirectional-new-file" "input.txt" "other.txt"
  --left-column  e.g. "-u" "--ignore-file-name-case" "--left-column" "--unidirectional-new-file" "input.txt" "other.txt"
  --no-dereference  e.g. "--unified" "--color" "--no-dereference" "--unidirectional-new-file" "input.txt" "other.txt"
  --no-ignore-file-name-case  e.g. "-u" "--color" "--no-ignore-file-name-case" "input.txt" "other.txt"
  --normal  e.g. (pairwise evidence)
  --palette  e.g. (pairwise evidence)
  --speed-large-files  e.g. "--unified" "--color" "--no-dereference" "--speed-large-files" "input.txt" "other.txt"
  --suppress-common-lines  e.g. "-u" "--color" "--left-column" "--suppress-common-lines" "input.txt" "other.txt"
  --unidirectional-new-file  e.g. "-u" "--ignore-file-name-case" "--left-column" "--unidirectional-new-file" "input.txt" "other.txt"
  -F  e.g. (pairwise evidence)
  -I  e.g. "-X" "-I" "input.txt" "other.txt"
  -S  e.g. "-X" "-S" "input.txt" "other.txt"
