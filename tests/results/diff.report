# Exploration: diff

## Rounds
  round 0: 302 isolated cumulative, 100 identical in round (single-phase)

## Observed: 49/53 flags
  6 solo, 43 via combination
  4 additional error-differentiated

Aliases: -B = --ignore-blank-lines, -D = --ifdef, -E = --ignore-tab-expansion, -F = --show-function-line, -I = --ignore-matching-lines, -N = --new-file, -S = --starting-file, -T = --initial-tab, -W = --width, -X = --exclude-from, -Z = --ignore-trailing-space, -a = --text, -b = --ignore-space-change, -d = --minimal, -e = --ed, -i = --ignore-case, -l = --paginate, -n = --rcs, -p = --show-c-function, -q = --brief, -r = --recursive, -s = --report-identical-files, -t = --expand-tabs, -w = --ignore-all-space, -x = --exclude, -y = --side-by-side

## Solo (unique behavior)
  --horizon-lines  # keep NUM lines of the common prefix and suffix
    exemplar: "--horizon-lines=1" "input.txt" "other.txt" in formatted_minimal (-48 lines)
    base:
      1,24c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
    flag:
      1,24c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
  --tabsize  # tab stops every NUM (default 8) print columns
    exemplar: "--tabsize=1" "input.txt" "other.txt" in formatted_minimal (-48 lines)
    base:
      1,24c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
    flag:
      1,24c1
      < first line
      < second line with trailing spaces
      < 	indented with tab
      <     indented with spaces
            ...
  --unified
    exemplar: "--unified" "input.txt" "other.txt" in words_minimal (+1516 lines, exit 127→1)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      --- input.txt	2026-05-11 18:21:48.912640679 -0700
      +++ other.txt	2026-05-11 18:21:48.912650067 -0700
      @@ -1,1512 +1 @@
      -aardvark
      -abbreviation
            ...
  -D  # output merged file with '#ifdef NAME' diffs
  -W  # output at most NUM (default 130) print columns
  -u
    exemplar: "-u" "input.txt" "other.txt" in words_minimal (+1516 lines, exit 127→1)
    base:
      1,1512c1
      < aardvark
      < abbreviation
      < about
      < abstract
            ...
    flag:
      --- input.txt	2026-05-11 18:21:48.911505976 -0700
      +++ other.txt	2026-05-11 18:21:48.911521996 -0700
      @@ -1,1512 +1 @@
      -aardvark
      -abbreviation
            ...

## Via combination (distinguishable when paired)
  --GTYPE-group-format  e.g. "-X" "--GTYPE-group-format=gfmt" "input.txt" "other.txt"
  --LTYPE-line-format  e.g. "-D" "--LTYPE-line-format=lfmt" "input.txt" "other.txt"
  --color  e.g. "--unified" "--color" "input.txt" "other.txt"
  --context  e.g. "-X" "--context" "input.txt" "other.txt"
  --from-file  e.g. "--from-file=input.txt" "--unified" "input.txt" "other.txt"
  --ignore-file-name-case  e.g. "-u" "--ignore-file-name-case" "input.txt" "other.txt"
  --label  e.g. "-D" "--label=test" "input.txt" "other.txt"
  --left-column  e.g. "-u" "--left-column" "input.txt" "other.txt"
  --line-format  e.g. "-D" "--line-format=lfmt" "input.txt" "other.txt"
  --no-dereference  e.g. "--no-dereference" "-u" "input.txt" "other.txt"
  --no-ignore-file-name-case  e.g. "-D" "--no-ignore-file-name-case" "input.txt" "other.txt"
  --normal  e.g. "-X" "--normal" "input.txt" "other.txt"
