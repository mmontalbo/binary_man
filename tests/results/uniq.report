# Exploration: uniq

## Rounds
  round 0: 80 isolated cumulative, 69 identical in round (single-phase)

## Observed: 11/11 flags
  4 solo, 7 via combination
  1 behavioral aliases detected

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --group
    exemplar: "--group" "input.txt" in words_minimal (+2882 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      
      abbreviation
      
      about
            ...
  -f  # avoid comparing the first N fields
    exemplar: "-f" "2" "input.txt" in numbers_minimal (different)
    base:
      0
      1
      1.00
      $1.00
      1/2
            ...
    flag:
      0
      1 000 000.00
      1'000'000.00
      1 000 000,00
      1'000'000,00
  -s  # avoid comparing the first N characters
    exemplar: "-s" "2" "input.txt" in numbers_minimal (different)
    base:
      0
      1
      1.00
      $1.00
      1/2
            ...
    flag:
      0
      1.00
      $1.00
      1/2
      1E02
            ...
  -w  # compare no more than N characters in lines
    exemplar: "-w" "2" "input.txt" in words_minimal (+269 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      abbreviation
      accept
      Africa
      afternoon
            ...

## Via combination (distinguishable when paired)
  --all-repeated  e.g. "-d" "--all-repeated" "input.txt" "other.txt"
  -D  e.g. "-d" "-D" "input.txt" "other.txt"
  -c  e.g. "-c" "-w" "1" "input.txt" "other.txt"
  -d  e.g. "-d" "-D" "input.txt" "other.txt"
  -i  e.g. "-f" "1" "-i" "input.txt" "other.txt"
  -u  e.g. "-u" "-i" "input.txt" "other.txt"
  -z  e.g. "-z" "-c" "input.txt" "other.txt"

