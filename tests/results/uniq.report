# Exploration: uniq

## Rounds
  round 0: 79 isolated cumulative, 66 identical in round (single-phase)

## Observed: 11/11 flags
  8 solo, 3 via combination
  2 behavioral aliases detected
  robustness: 11 robust, 0 moderate, 0 fragile

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --group
    exemplar: "--group" "input.txt" in words_minimal (+2882 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      
      abbreviation
      
      about
            ...
  -c  # prefix lines by the number of occurrences
    exemplar: "-c" "input.txt" in words_minimal (+1441 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
            1 aardvark
            1 abbreviation
            1 about
            1 abstract
            1 accept
            ...
  -d  # only print duplicate lines, one for each group
    exemplar: "-d" "input.txt" in formatted_minimal (+1 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
  -f  # avoid comparing the first N fields
    exemplar: "-f" "1" "input.txt" in words_minimal (-6 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      San Francisco
      Saturday
  -s  # avoid comparing the first N characters
    exemplar: "-s" "1" "input.txt" in numbers_minimal (different)
    base:
      0
      1
      1.00
      $1.00
      1/2
            ...
    flag:
      0
      1.00
      $1.00
      1/2
      1E2
            ...
  -u  # only print unique lines
    exemplar: "-u" "input.txt" in formatted_minimal (-46 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
  -w  # compare no more than N characters in lines
    exemplar: "-w" "1" "input.txt" in words_minimal (+162 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      Africa
      afternoon
      Alice
      all
            ...
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" in words_minimal (+1441 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...

## Via combination (distinguishable when paired)
  --all-repeated  e.g. (pairwise evidence)
  -D  e.g. (pairwise evidence)
  -i  e.g. "-c" "-i" "input.txt" "other.txt"

