# Exploration: uniq

## Rounds
  round 0: 18 isolated cumulative, 35 identical in round (discovery)
  round 1: 37 isolated cumulative, 23 identical in round (refinement)
  round 2: 44 isolated cumulative, 21 identical in round (refinement)
  round 3: 49 isolated cumulative, 21 identical in round (refinement)

## Observed: 11/11 flags
  11 solo, 0 via combination

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --all-repeated
    exemplar: "--all-repeated" "input.txt" in formatted_minimal (+2 lines)
    base:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
    flag:
      
  --group
    exemplar: "--group" "input.txt" in alpha_minimal (-18 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      
      Apple
      
      banana
            ...
  -D  # print all duplicate lines
    exemplar: "-D" "input.txt" in formatted_minimal (+2 lines)
    base:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
    flag:
      
  -c  # prefix lines by the number of occurrences
    exemplar: "-c" "input.txt" in alpha_minimal (-9 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
            1 cherry
            1 Apple
            1 banana
            1 Date
            1 elderberry
            ...
  -d  # only print duplicate lines, one for each group
    exemplar: "-d" "input.txt" in formatted_minimal (+1 lines)
    base:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
    flag:
  -f  # avoid comparing the first N fields
    exemplar: "-f" in formatted_minimal (different)
    base:
    flag:
  -i  # ignore differences in case when comparing
    exemplar: "-i" "input.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
    flag:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
  -s  # avoid comparing the first N characters
    exemplar: "-s" "input.txt" "other.txt" in formatted_minimal (different)
    base:
    flag:
  -u  # only print unique lines
    exemplar: "-u" "input.txt" in formatted_minimal (-5 lines)
    base:
      first line
      
      	indented with tab
      trailing spaces   
      
            ...
    flag:
      first line
      	indented with tab
      trailing spaces   
      
        leading spaces
            ...
  -w  # compare no more than N characters in lines
    exemplar: "-w" "input.txt" "other.txt" in formatted_minimal (different)
    base:
    flag:
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" in alpha_minimal (-9 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...

