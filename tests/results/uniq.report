# Exploration: uniq

## Rounds
  round 0: 42 isolated cumulative, 41 identical in round (single-phase)

## Observed: 11/11 flags
  4 solo, 7 via combination

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --group
    exemplar: "--group" "input.txt" in words_minimal (+2882 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      
      abbreviation
      
      about
            ...
  -f  # avoid comparing the first N fields
    exemplar: "-f" in formatted_minimal (different)
    base:
    flag:
  -s  # avoid comparing the first N characters
    exemplar: "-s" in formatted_minimal (different)
    base:
    flag:
  -w  # compare no more than N characters in lines
    exemplar: "-w" in formatted_minimal (different)
    base:
    flag:

## Via combination (distinguishable when paired)
  --all-repeated  e.g. "-d" "--all-repeated" "input.txt" "other.txt"
  -D  e.g. "-D" "-u" "input.txt" "other.txt"
  -c  e.g. "-c" "-d" "input.txt" "other.txt"
  -d  e.g. "-d" "--all-repeated" "input.txt" "other.txt"
  -i  e.g. "-f" "-i" "input.txt" "other.txt"
  -u  e.g. "-D" "-u" "input.txt" "other.txt"
  -z  e.g. "-D" "-z" "input.txt" "other.txt"

