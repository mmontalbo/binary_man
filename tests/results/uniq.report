# Exploration: uniq

## Rounds
  round 0: 55 isolated cumulative, 83 identical in round (single-phase)

## Observed: 11/11 flags
  11 solo, 0 via combination
  3 behavioral aliases detected
  robustness: 11 robust, 0 moderate, 0 fragile

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --all-repeated
    exemplar: "--all-repeated" "input.txt" in formatted_minimal (+2 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      
  --group
    exemplar: "--group" "input.txt" in words_minimal (+2882 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      
      abbreviation
      
      about
            ...
  -D  # print all duplicate lines
    exemplar: "-D" "input.txt" in formatted_minimal (+2 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      
  -c  # prefix lines by the number of occurrences
    exemplar: "-c" "input.txt" in words_minimal (+1441 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
            1 aardvark
            1 abbreviation
            1 about
            1 abstract
            1 accept
            ...
  -d  # only print duplicate lines, one for each group
    exemplar: "-d" "input.txt" in formatted_minimal (+1 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
  -f  # avoid comparing the first N fields
    exemplar: "-f" "2" "input.txt" in numbers_minimal (different)
    base:
      0
      1
      1.00
      $1.00
      1/2
            ...
    flag:
      0
      1 000 000.00
      1'000'000.00
      1 000 000,00
      1'000'000,00
  -i  # ignore differences in case when comparing
    exemplar: "-i" in words_minimal (different)
    base:
    flag:
      cherry
      apple
      banana
  -s  # avoid comparing the first N characters
    exemplar: "-s" "2" "input.txt" in numbers_minimal (different)
    base:
      0
      1
      1.00
      $1.00
      1/2
            ...
    flag:
      0
      1.00
      $1.00
      1/2
      1E02
            ...
  -u  # only print unique lines
    exemplar: "-u" "input.txt" in formatted_minimal (-49 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
  -w  # compare no more than N characters in lines
    exemplar: "-w" "2" "input.txt" in words_minimal (+269 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      abbreviation
      accept
      Africa
      afternoon
            ...
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" in words_minimal (+1441 lines)
    base:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...

