# Exploration: uniq

## Rounds
  round 0: 36 isolated cumulative, 12 identical in round (discovery)
  round 1: 36 isolated cumulative, 27 identical in round (refinement)

## Distinguished: 11/11 flags
  11 observed behavior (8 solo, 3 via combination)
  1 behavioral aliases detected

Aliases: -c = --count, -d = --repeated, -f = --skip-fields, -i = --ignore-case, -s = --skip-chars, -u = --unique, -w = --check-chars, -z = --zero-terminated

## Solo (unique behavior)
  --group
    exemplar: "--group" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -c  # prefix lines by the number of occurrences
    exemplar: "-c" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -d  # only print duplicate lines, one for each group
    exemplar: "-d" "input.txt" "other.txt" in fielded_deep (different)
    base:
    flag:
  -f  # avoid comparing the first N fields
    exemplar: "-f" "input.txt" "other.txt" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -s  # avoid comparing the first N characters
    exemplar: "-s" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -u  # only print unique lines
    exemplar: "-u" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -w  # compare no more than N characters in lines
    exemplar: "-w" "input.txt" "other.txt" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -z  # line delimiter is NUL, not newline
    exemplar: "-z" "input.txt" "other.txt" in alpha_minimal (different)
    base:
