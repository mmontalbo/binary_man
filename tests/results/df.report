# Exploration: df

## Rounds
  round 0: 308 isolated cumulative, 40 identical in round (single-phase)

## Observed: 15/16 flags
  13 solo, 2 via combination
  1 additional error-differentiated

Aliases: -B = --block-size, -H = --si, -P = --portability, -T = --print-type, -a = --all, -h = --human-readable, -i = --inodes, -l = --local, -t = --type, -x = --exclude-type

