# Exploration: fmt

## Rounds
  round 0: 18 isolated cumulative, 47 identical in round (single-phase)

## Observed: 7/7 flags
  3 solo, 4 via combination

Aliases: -c = --crown-margin, -g = --goal, -p = --prefix, -s = --split-only, -t = --tagged-paragraph, -u = --uniform-spacing, -w = --width

## Solo (unique behavior)
  -g  # goal width (default of 93% of width)
    exemplar: "-g" in numeric_minimal (different)
    base:
    flag:
  -p  # reformat only lines beginning with STRING,
    exemplar: "-p" "input.txt" "other.txt" in alpha_minimal (-1 lines)
    base:
      cherry Apple banana Date elderberry BANANA apple
      hello world
    flag:
      hello world
  -w  # maximum line width (default of 75 columns)
    exemplar: "-w" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100 2 30 1 20 3 10 50 8 200 15 99 7 42 1000 5
    flag:
      100 2 30 1 20 3 10 50 8 200 15 99 7 42 1000 5

## Via combination (distinguishable when paired)
  -c  e.g. "-c" "-u" "$(head -n1 input.txt)" "input.txt"
  -s  e.g. (pairwise evidence)
  -t  e.g. (pairwise evidence)
  -u  e.g. "-c" "-u" "$(head -n1 input.txt)" "input.txt"

