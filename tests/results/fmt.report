# Exploration: fmt

## Rounds
  round 0: 19 isolated cumulative, 46 identical in round (discovery)
  round 1: 59 isolated cumulative, 32 identical in round (refinement)
  round 2: 59 isolated cumulative, 32 identical in round (refinement)

## Observed: 7/7 flags
  7 solo, 0 via combination
  1 behavioral aliases detected

Aliases: -c = --crown-margin, -g = --goal, -p = --prefix, -s = --split-only, -t = --tagged-paragraph, -u = --uniform-spacing, -w = --width

## Solo (unique behavior)
  -c  # preserve indentation of first two lines
    exemplar: "-c" "input.txt" in alpha_standard / content_case_upper (reordered)
    base:
      (no base)
    flag:
      CHERRY APPLE BANANA DATE ELDERBERRY BANANA APPLE
  -g  # goal width (default of 93% of width)
    exemplar: "-g" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      CHERRY APPLE BANANA DATE ELDERBERRY BANANA APPLE
    flag:
  -p  # reformat only lines beginning with STRING,
    exemplar: "-p" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      other content
      second line
  -s  # split long lines, but do not refill
    exemplar: "-s" "input.txt" in alpha_standard / content_ws_trailing (different)
    base:
      (no base)
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -t  # indentation of first line different from second
    exemplar: "-t" "input.txt" in alpha_standard / content_ws_trailing (different)
    base:
      (no base)
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -u  # one space between words, two after sentences
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (+10 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
  -w  # maximum line width (default of 75 columns)
    exemplar: "-w" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      CHERRY APPLE BANANA DATE ELDERBERRY BANANA APPLE
    flag:

