# Exploration: fmt

## Rounds
  round 0: 126 isolated cumulative, 70 identical in round (single-phase)

## Observed: 7/7 flags
  7 solo, 0 via combination
  1 behavioral aliases detected
  robustness: 5 robust, 0 moderate, 0 fragile

Aliases: -c = --crown-margin, -g = --goal, -p = --prefix, -s = --split-only, -t = --tagged-paragraph, -u = --uniform-spacing, -w = --width

## Solo (unique behavior)
  -c  # preserve indentation of first two lines
    exemplar: "-c" "input.txt" "other.txt" in formatted_minimal (+14 lines)
    base:
      first line second line with trailing spaces
      	indented with tab
          indented with spaces
      		mixed tabs and spaces
      
            ...
    flag:
      first line second line with trailing spaces
      	indented with tab indented with spaces
      		mixed tabs and spaces
      
      blank line above
            ...
  -g  # goal width (default of 93% of width)
    exemplar: "-g" "1" "input.txt" "other.txt" in words_minimal (+1315 lines)
    base:
      aardvark abbreviation about abstract accept accepted accepting access
      accommodate acknowledge across Africa afternoon again against aggregate
      ahead algorithm Alice all already also although always Amazon American
      among an and another answer Apache apostrophe Apple application
      approximately architect Argentina around arrange Asia assembly
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...
  -p  # reformat only lines beginning with STRING, reattaching the prefix to reformatted lines
    exemplar: "-p" "test" "input.txt" "other.txt" in numbers_standard / input.txt=size:1 (-71 lines)
    base:
      x
      other content second line
    flag:
      xother content
      second line
  -s  # split long lines, but do not refill
    exemplar: "-s" "input.txt" "other.txt" in passwd_minimal (-40 lines)
    base:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin sync:x:4:65534:sync:/bin:/bin/sync
      games:x:5:60:games:/usr/games:/usr/sbin/nologin
            ...
    flag:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
  -t  # indentation of first line different from second
    exemplar: "-t" "input.txt" "other.txt" in passwd_minimal (-40 lines)
    base:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin sync:x:4:65534:sync:/bin:/bin/sync
      games:x:5:60:games:/usr/games:/usr/sbin/nologin
            ...
    flag:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
  -u  # one space between words, two after sentences
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (+15 lines)
    base:
      first line second line with trailing spaces
      	indented with tab
          indented with spaces
      		mixed tabs and spaces
      
            ...
    flag:
      first line second line with trailing spaces
      	indented with tab
          indented with spaces
      		mixed tabs and spaces
      
            ...
  -w  # maximum line width (default of 75 columns)
    exemplar: "-w" "10" "input.txt" "other.txt" in words_minimal (+1322 lines)
    base:
      aardvark abbreviation about abstract accept accepted accepting access
      accommodate acknowledge across Africa afternoon again against aggregate
      ahead algorithm Alice all already also although always Amazon American
      among an and another answer Apache apostrophe Apple application
      approximately architect Argentina around arrange Asia assembly
            ...
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...

