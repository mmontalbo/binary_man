# Exploration: fmt

## Rounds
  round 0: 18 isolated cumulative, 45 identical in round (discovery)
  round 1: 59 isolated cumulative, 31 identical in round (refinement)
  round 2: 59 isolated cumulative, 31 identical in round (refinement)

## Distinguished: 7/7 flags (6 observed behavior)
  6 observed behavior (6 solo, 0 via combination)
  1 error-differentiated only (1 solo, 0 via combination)
  2 behavioral aliases detected

Aliases: -c = --crown-margin, -g = --goal, -p = --prefix, -s = --split-only, -t = --tagged-paragraph, -u = --uniform-spacing, -w = --width

## Solo (unique behavior)
  -c  # preserve indentation of first two lines
    exemplar: "-c" "input.txt" "other.txt" in formatted_standard (+7 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab trailing spaces
      
            ...
  -g  # goal width (default of 93% of width)
    exemplar: "-g" "input.txt" "subdir" in alpha_minimal (different)
    base:
      cherry Apple banana Date elderberry BANANA apple
    flag:
  -p  # reformat only lines beginning with STRING,
    exemplar: "-p" "input.txt" "other.txt" in alpha_minimal (-1 lines)
    base:
      cherry Apple banana Date elderberry BANANA apple
      hello world
    flag:
      hello world
  -s  # split long lines, but do not refill
    exemplar: "-s" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
  -t  # indentation of first line different from second
    exemplar: "-t" "input.txt" "other.txt" in formatted_standard (-8 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab trailing spaces
      
            ...
  -u  # one space between words, two after sentences
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (+10 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
  -w  # maximum line width (default of 75 columns)
    exemplar: "-w" "input.txt" "subdir" in alpha_minimal (different)
    base:
      cherry Apple banana Date elderberry BANANA apple
    flag:

