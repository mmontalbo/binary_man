# Exploration: fmt

## Rounds
  round 0: 19 isolated cumulative, 46 identical in round (discovery)
  round 1: 59 isolated cumulative, 32 identical in round (refinement)
  round 2: 59 isolated cumulative, 32 identical in round (refinement)

## Observed: 7/7 flags
  7 solo, 0 via combination
  2 behavioral aliases detected

Aliases: -c = --crown-margin, -g = --goal, -p = --prefix, -s = --split-only, -t = --tagged-paragraph, -u = --uniform-spacing, -w = --width

## Solo (unique behavior)
  -c  # preserve indentation of first two lines
    exemplar: "-c" "input.txt" "other.txt" in formatted_standard (+7 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab trailing spaces
      
            ...
  -g  # goal width (default of 93% of width)
    exemplar: "-g" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
  -p  # reformat only lines beginning with STRING,
    exemplar: "-p" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      other content
      second line
  -s  # split long lines, but do not refill
    exemplar: "-s" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
  -t  # indentation of first line different from second
    exemplar: "-t" "input.txt" "other.txt" in formatted_standard (-8 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab trailing spaces
      
            ...
  -u  # one space between words, two after sentences
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (+10 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces
            ...
  -w  # maximum line width (default of 75 columns)
    exemplar: "-w" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
      100 2 30 1 20 3 10 50 8 200 15 99 7 42 1000 5

