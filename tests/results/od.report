## Distinguishable in combination (verified via flag pairs)
  --traditional  # accept arguments in third form above
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: "-j" "1" "--traditional" "$(head -n1 input.txt)" "input.txt"
  --width
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: (pairwise evidence)
  -S
    | flag removes 1 lines: 0000000
    | exit: 0 → 1
    | stderr: od: option requires an argument -- 'S'
    proven via: (pairwise evidence)
  -d  # same as -t u2, select unsigned decimal 2-byte units
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: "-j" "1" "-d" "$(head -n1 input.txt)" "input.txt"
  -o  # same as -t o2, select octal 2-byte units
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: "-j" "1" "-o" "input.txt" "other.txt"
  -s  # same as -t d2, select decimal 2-byte units
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: "-j" "1" "-s" "input.txt"
  -v  # do not use * to mark line suppression
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: (pairwise evidence)
  -w
    | flag adds 1 lines: 0000001
    | exit: 1 → 0
    | stderr removed
    proven via: (pairwise evidence)

