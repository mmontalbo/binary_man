# Exploration: nl

## Rounds
  round 0: 155 isolated cumulative, 105 identical in round (single-phase)

## Observed: 9/11 flags
  5 solo, 4 via combination
  1 additional error-differentiated
  robustness: 8 robust, 0 moderate, 0 fragile

Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -i  # line number increment at each line
    exemplar: "-i" "2" in words_minimal / stdin (+3 lines)
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           1	cherry
           3	apple
           5	banana
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" "1" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
           1	first line
           2	second line with trailing spaces
           3		indented with tab
           4	    indented with spaces
           5		 	mixed tabs and spaces
            ...
    flag:
           1	first line
           2	second line with trailing spaces
           3		indented with tab
           4	    indented with spaces
           5		 	mixed tabs and spaces
            ...
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" "%s" in numbers_minimal / stdin (different)
    base:
           1	cherry
           2	apple
           3	banana
    flag:
  -s  # add STRING after (possible) line number
    exemplar: "-s" "x" in words_minimal / stdin (+3 lines)
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           1xcherry
           2xapple
           3xbanana
  -v  # first line number for each section
    exemplar: "-v" "2" in words_minimal / stdin (+3 lines)
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           2	cherry
           3	apple
           4	banana
  -w  # use NUMBER columns for line numbers
    exemplar: "-w" "2" in words_minimal / stdin (+3 lines)
    base:
           1	cherry
           2	apple
           3	banana
    flag:
       1	cherry
       2	apple
       3	banana

