Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -b  # use STYLE for numbering body lines
    exemplar: "-b" "alpha" "input.txt" in empty_dir (-16 lines, exit 0→1)
    base:
    flag:
  -d  # use CC for logical page delimiters
    exemplar: "-d" "alpha" "input.txt" in empty_dir (-16 lines, exit 0→1)
    base:
    flag:
  -f  # use STYLE for numbering footer lines
    exemplar: "-f" "alpha" "input.txt" in empty_dir (-16 lines, exit 0→1)
    base:
    flag:
  -h  # use STYLE for numbering header lines
    exemplar: "-h" "alpha" "input.txt" in empty_dir (-16 lines, exit 0→1)
    base:
    flag:
  -i  # line number increment at each line
    exemplar: "-i" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -s  # add STRING after (possible) line number
    exemplar: "-s" "alpha" "input.txt" in empty_dir (-16 lines, exit 0→1)
    base:
    flag:
  -v  # first line number for each section
    exemplar: "-v" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -w  # use NUMBER columns for line numbers
    exemplar: "-w" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:

