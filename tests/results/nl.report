# Exploration: nl

## Rounds
  round 0: 115 isolated cumulative, 94 identical in round (single-phase)

## Observed: 9/11 flags
  5 solo, 4 via combination
  1 additional error-differentiated
  1 behavioral aliases detected
  robustness: 8 robust, 0 moderate, 0 fragile

Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -i  # line number increment at each line
    exemplar: "-i" "0" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1	aardvark
           1	abbreviation
           1	about
           1	abstract
           1	accept
            ...
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" "1" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
           1	first line
           2	second line with trailing spaces
           3		indented with tab
           4	    indented with spaces
           5		 	mixed tabs and spaces
            ...
    flag:
           1	first line
           2	second line with trailing spaces
           3		indented with tab
           4	    indented with spaces
           5		 	mixed tabs and spaces
            ...
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" "%s" in words_minimal (different)
    base:
    flag:
  -s  # add STRING after (possible) line number
    exemplar: "-s" "x" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1xaardvark
           2xabbreviation
           3xabout
           4xabstract
           5xaccept
            ...
  -v  # first line number for each section
    exemplar: "-v" "0" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           0	aardvark
           1	abbreviation
           2	about
           3	abstract
           4	accept
            ...
  -w  # use NUMBER columns for line numbers
    exemplar: "-w" "2" "input.txt" "other.txt" in words_minimal (+1440 lines)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
       1	aardvark
       2	abbreviation
       3	about
       4	abstract
       5	accept
            ...

