# Exploration: nl

## Rounds
  round 0: 138 isolated cumulative, 69 identical in round (single-phase)

## Observed: 10/11 flags
  9 solo, 1 via combination
  1 additional error-differentiated
  1 behavioral aliases detected

Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -b  # use STYLE for numbering body lines
    exemplar: "-b" "$(head -n1 input.txt)" "input.txt" in words_minimal (+1512 lines, exit 1→0)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
  -d  # use CC for logical page delimiters
    exemplar: "-d" "input.txt" "other.txt" in words_minimal (-1 lines)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1	hello world
  -f  # use STYLE for numbering footer lines
    exemplar: "-f" "$(head -n1 input.txt)" "input.txt" in words_minimal (+1512 lines, exit 1→0)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
  -h  # use STYLE for numbering header lines
    exemplar: "-h" "$(head -n1 input.txt)" "input.txt" in words_minimal (+1512 lines, exit 1→0)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
  -i  # line number increment at each line
    exemplar: "-i" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
           1	0
           2	1
           3	1.00
           4	$1.00
           5	1/2
            ...
    flag:
           1	0
           1	1
           1	1.00
           1	$1.00
           1	1/2
            ...
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" in words_minimal (different)
    base:
    flag:
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" in words_minimal (different)
    base:
    flag:
  -s  # add STRING after (possible) line number
    exemplar: "-s" "input.txt" in words_minimal (different)
    base:
           1	aardvark
           2	abbreviation
           3	about
           4	abstract
           5	accept
            ...
    flag:
           1input.txtcherry
           2input.txtapple
           3input.txtbanana
  -v  # first line number for each section
    exemplar: "-v" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
           1	0
           2	1
           3	1.00
           4	$1.00
           5	1/2
            ...
    flag:
           0	0
           1	1
           2	1.00
           3	$1.00
           4	1/2
            ...
  -w  # use NUMBER columns for line numbers
    exemplar: "-w" in words_minimal (different)
    base:
    flag:

## Via combination (distinguishable when paired)
  -p  e.g. "-f" "-p" "$(head -n1 input.txt)" "input.txt"

