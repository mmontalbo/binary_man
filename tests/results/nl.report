# Exploration: nl

## Rounds
  round 0: 48 isolated cumulative, 68 identical in round (discovery)
  round 1: 76 isolated cumulative, 11 identical in round (refinement)
  round 2: 77 isolated cumulative, 11 identical in round (refinement)
  round 3: 77 isolated cumulative, 11 identical in round (refinement)

## Observed: 10/11 flags
  10 solo, 0 via combination
  1 additional error-differentiated
  3 behavioral aliases detected

Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -b  # use STYLE for numbering body lines
    exemplar: "-b" "$(head -n1 input.txt)" "input.txt" in tabular_minimal (+12 lines, exit 1→0)
    base:
           1	name	age	city
           2	alice	30	new york
           3	bob	25	san francisco
           4	alice	30	new york
           5	charlie	35	chicago
            ...
    flag:
             name	age	city
             alice	30	new york
             bob	25	san francisco
             alice	30	new york
             charlie	35	chicago
            ...
  -d  # use CC for logical page delimiters
    exemplar: "-d" "input.txt" "other.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
           1	other content
           2	second line
  -f  # use STYLE for numbering footer lines
    exemplar: "-f" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      (no base)
    flag:
  -h  # use STYLE for numbering header lines
    exemplar: "-h" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      (no base)
    flag:
  -i  # line number increment at each line
    exemplar: "-i" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
           1	100
         101	2
         201	30
         301	1
         401	20
            ...
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      (no base)
    flag:
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" "input.txt" "subdir" in alpha_standard / content_case_upper (different)
    base:
      (no base)
    flag:
  -p  # do not reset line numbers for each section
    exemplar: "-p" "input.txt" in alpha_standard / content_case_upper (reordered)
    base:
           1	CHERRY
           2	APPLE
           3	BANANA
           4	DATE
           5	ELDERBERRY
            ...
    flag:
           1	CHERRY
           2	APPLE
           3	BANANA
           4	DATE
           5	ELDERBERRY
            ...
  -s  # add STRING after (possible) line number
    exemplar: "-s" "input.txt" in alpha_minimal (different)
    base:
      (no base)
    flag:
           1input.txtcherry
           2input.txtapple
           3input.txtbanana
  -v  # first line number for each section
    exemplar: "-v" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
         100	100
         101	2
         102	30
         103	1
         104	20
            ...
  -w  # use NUMBER columns for line numbers
    exemplar: "-w" "$(head -n1 input.txt)" "input.txt" in many_files /remove env LC_ALL (different)
    base:
      (no base)
    flag:
                                                                                                         1	100
                                                                                                         2	2
                                                                                                         3	30
                                                                                                         4	1
                                                                                                         5	20
            ...

