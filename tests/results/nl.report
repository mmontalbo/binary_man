# Exploration: nl

## Rounds
  round 0: 146 isolated cumulative, 105 identical in round (single-phase)

## Observed: 10/11 flags
  5 solo, 5 via combination
  1 additional error-differentiated
  1 behavioral aliases detected
  robustness: 10 robust, 0 moderate, 0 fragile

Aliases: -b = --body-numbering, -d = --section-delimiter, -f = --footer-numbering, -h = --header-numbering, -i = --line-increment, -l = --join-blank-lines, -n = --number-format, -p = --no-renumber, -s = --number-separator, -v = --starting-line-number, -w = --number-width

## Solo (unique behavior)
  -i  # line number increment at each line
    exemplar: "--line-increment=2" in words_minimal / stdin
    | 2 only in this:      3	apple,      5	banana
    | 2 only in ref:      2	apple,      3	banana
    | 1 shared
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           1	cherry
           3	apple
           5	banana
  -l  # group of NUMBER empty lines counted as one
    exemplar: "-l" "1" in words_minimal / stdin
    | 3 only in ref:      1	cherry,      2	apple,      3	banana
    | exit: 0 → 1
    | stderr: nl: option requires an argument -- 'l'
    base:
           1	cherry
           2	apple
           3	banana
    flag:
  -n  # insert line numbers according to FORMAT
    exemplar: "-n" "%s" in words_minimal / stdin
    | 3 only in ref:      1	cherry,      2	apple,      3	banana
    | exit: 0 → 1
    | stderr: nl: invalid line numbering format: '%s'
    base:
           1	cherry
           2	apple
           3	banana
    flag:
  -s  # add STRING after (possible) line number
    exemplar: "-s" "x" in words_minimal / stdin
    | 3 only in this:      1xcherry,      2xapple,      3xbanana
    | 3 only in ref:      1	cherry,      2	apple,      3	banana
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           1xcherry
           2xapple
           3xbanana
  -v  # first line number for each section
    exemplar: "--starting-line-number=2" in words_minimal / stdin
    | 3 only in this:      2	cherry,      3	apple,      4	banana
    | 3 only in ref:      1	cherry,      2	apple,      3	banana
    base:
           1	cherry
           2	apple
           3	banana
    flag:
           2	cherry
           3	apple
           4	banana
  -w  # use NUMBER columns for line numbers
    exemplar: "--number-width=2" in words_minimal / stdin
    | 3 only in this:  1	cherry,  2	apple,  3	banana
    | 3 only in ref:      1	cherry,      2	apple,      3	banana
    base:
           1	cherry
           2	apple
           3	banana
    flag:
       1	cherry
       2	apple
       3	banana

## Via combination (distinguishable when paired)
  -b  # use STYLE for numbering body lines
    | 71 only in this:        0,        1,        1.00,        $1.00,        1/2
    | 71 only in ref:      1	0,      2	1,      3	1.00,      4	$1.00,      5	1/2
    evidence: (pairwise evidence)
  -d  # use CC for logical page delimiters
    | exit: 0 → 1
    | stderr: nl: option requires an argument -- 'd'
    evidence: (pairwise evidence)
  -f  # use STYLE for numbering footer lines
    | 1512 only in ref:      1	aardvark,      2	abbreviation,      3	about,      4	abstract,      5	accept
    | stderr changed: nl: invalid line numbering format: '%s'
    evidence: (pairwise evidence)
  -h  # use STYLE for numbering header lines
    | 1512 only in ref:      1	aardvark,      2	abbreviation,      3	about,      4	abstract,      5	accept
    | stderr changed: nl: invalid line numbering format: '%s'
    evidence: (pairwise evidence)
  -p  # do not reset line numbers for each section
    | 1512 only in ref:      1	aardvark,      2	abbreviation,      3	about,      4	abstract,      5	accept
    | stderr changed: nl: invalid line numbering format: '%s'
    evidence: (pairwise evidence)

