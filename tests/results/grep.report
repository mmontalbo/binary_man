# Exploration: grep

## Rounds
  round 0: 77 isolated cumulative, 109 identical in round (single-phase)

## Observed: 45/49 flags
  19 solo, 26 via combination
  4 additional error-differentiated
  robustness: 48 robust, 0 moderate, 0 fragile

Aliases: -A = --after-context, -B = --before-context, -C = --context, -D = --devices, -E = --extended-regexp, -F = --fixed-strings, -G = --basic-regexp, -H = --with-filename, -L = --files-without-match, -P = --perl-regexp, -R = --dereference-recursive, -T = --initial-tab, -U = --binary, -Z = --null, -a = --text, -b = --byte-offset, -c = --count, -d = --directories, -e = --regexp, -f = --file, -h = --no-filename, -i = --ignore-case, -l = --files-with-matches, -m = --max-count, -n = --line-number, -o = --only-matching, -r = --recursive, -s = --no-messages, -v = --invert-match, -w = --word-regexp, -x = --line-regexp, -z = --null-data

## Solo (unique behavior)
  --exclude-from  # skip files that match any file pattern from FILE
    exemplar: "--exclude-from=input.txt" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
  -A  # print NUM lines of trailing context
    exemplar: "-A" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      1/2
            ...
  -B  # print NUM lines of leading context
    exemplar: "-B" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      --
            ...
  -C  # print NUM lines of output context
    exemplar: "-C" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      1/2
            ...
  -F  # PATTERNS are strings
    exemplar: "-F" "$(head -n1 input.txt)" "input.txt" in access_log_minimal (-47 lines)
    base:
    flag:
      192.168.1.1 - frank [10/Jan/2024:08:12:31 +0000] "GET /index.html HTTP/1.1" 200 3842 "https://www.example.com/" "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
  -H  # print file name with output lines
    exemplar: "-H" "$(head -n1 input.txt)" "input.txt" in words_standard (-47 lines)
    base:
      aardvark
    flag:
      input.txt:aardvark
  -L  # print only names of FILEs with no selected lines
    exemplar: "-L" "$(head -n1 input.txt)" "input.txt" in access_log_minimal (+1 lines, exit 0→1)
    base:
    flag:
      input.txt
  -V  # display version information and exit
    exemplar: "-V" "$(head -n1 input.txt)" "input.txt" in words_standard (different)
    base:
      aardvark
    flag:
      grep (GNU grep) 3.11
      Copyright (C) 2023 Free Software Foundation, Inc.
      License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
      This is free software: you are free to change and redistribute it.
      There is NO WARRANTY, to the extent permitted by law.
            ...
  -b  # print the byte offset with output lines
    exemplar: "-b" "$(head -n1 input.txt)" "input.txt" in words_standard (-47 lines)
    base:
      aardvark
    flag:
      0:aardvark
  -c  # print only a count of selected lines per FILE
    exemplar: "-c" "$(head -n1 input.txt)" "input.txt" in words_standard (different)
    base:
      aardvark
    flag:
      1
  -d  # how to handle directories; ACTION is 'read', 'recurse', or 'skip'
    exemplar: "-d" "1" "$(head -n1 input.txt)" "input.txt" in words_standard (different)
    base:
      aardvark
    flag:
  -l  # print only names of FILEs with selected lines
    exemplar: "-l" "$(head -n1 input.txt)" "input.txt" in words_standard (different)
    base:
      aardvark
    flag:
      input.txt
  -m  # stop after NUM selected lines
    exemplar: "-m" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1.00
  -n  # print line number with output lines
    exemplar: "-n" "$(head -n1 input.txt)" "input.txt" in words_standard (-47 lines)
    base:
      aardvark
    flag:
      1:aardvark
  -o  # show only nonempty parts of lines that match
    exemplar: "-o" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      0
      0
      0
      0
            ...
  -s  # suppress error messages
    exemplar: "-s" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
  -v  # select non-matching lines
    exemplar: "-v" "$(head -n1 input.txt)" "input.txt" in words_standard (+1488 lines)
    base:
      aardvark
    flag:
      abbreviation
      about
      abstract
      accept
      accepted
            ...
  -w  # match only whole words
    exemplar: "-w" "$(head -n1 input.txt)" "input.txt" in numbers_standard (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1/0
      0/0
      -0
      -0.0
            ...
  -z  # a data line ends in 0 byte, not newline
    exemplar: "-z" "$(head -n1 input.txt)" "input.txt" in words_standard (+1441 lines)
    base:
      aardvark
    flag:
      aardvark
      abbreviation
      about
      abstract
      accept
            ...

