# Exploration: grep

## Rounds
  round 0: 49 isolated cumulative, 133 identical in round (single-phase)

## Observed: 45/49 flags
  6 solo, 39 via combination
  4 additional error-differentiated
  robustness: 48 robust, 0 moderate, 0 fragile

Aliases: -A = --after-context, -B = --before-context, -C = --context, -D = --devices, -E = --extended-regexp, -F = --fixed-strings, -G = --basic-regexp, -H = --with-filename, -L = --files-without-match, -P = --perl-regexp, -R = --dereference-recursive, -T = --initial-tab, -U = --binary, -Z = --null, -a = --text, -b = --byte-offset, -c = --count, -d = --directories, -e = --regexp, -f = --file, -h = --no-filename, -i = --ignore-case, -l = --files-with-matches, -m = --max-count, -n = --line-number, -o = --only-matching, -r = --recursive, -s = --no-messages, -v = --invert-match, -w = --word-regexp, -x = --line-regexp, -z = --null-data

## Solo (unique behavior)
  --exclude-from  # skip files that match any file pattern from FILE
    exemplar: "--exclude-from=input.txt" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
  -A  # print NUM lines of trailing context
    exemplar: "-A" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      1/2
            ...
  -B  # print NUM lines of leading context
    exemplar: "-B" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      1/2
            ...
  -C  # print NUM lines of output context
    exemplar: "-C" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1
      1.00
      $1.00
      1/2
            ...
  -d  # how to handle directories; ACTION is 'read', 'recurse', or 'skip'
    exemplar: "-d" "1" "$(head -n1 input.txt)" "input.txt" in words_minimal (different)
    base:
      aardvark
    flag:
  -m  # stop after NUM selected lines
    exemplar: "-m" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal (different)
    base:
      0
      1.00
      $1.00
      1E02
      1E+02
            ...
    flag:
      0
      1.00

