## Solo (unique behavior)
  --binary-files  # assume that binary files are TYPE;
  -D  # how to handle devices, FIFOs and sockets;
  -L  # print only names of FILEs with no selected lines
    exemplar: "-L" "input.txt" in alpha_minimal (different)
    base:
    flag:
      (standard input)
  -V  # display version information and exit
    exemplar: "-V" "input.txt" in alpha_minimal (different)
    base:
    flag:
      grep (GNU grep) 3.11
      Copyright (C) 2023 Free Software Foundation, Inc.
      License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
      This is free software: you are free to change and redistribute it.
      There is NO WARRANTY, to the extent permitted by law.
            ...
  -c  # print only a count of selected lines per FILE
    exemplar: "-c" "input.txt" in alpha_minimal (different)
    base:
    flag:
      0
  -d  # how to handle directories;
    exemplar: "-d" "input.txt" in tabular_minimal (different)
    base:
    flag:
  -f  # take PATTERNS from FILE
    exemplar: "-f" "input.txt" in tabular_minimal (different)
    base:
    flag:
  -m  # stop after NUM selected lines

