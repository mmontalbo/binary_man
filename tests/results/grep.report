# Exploration: grep

## Rounds
  round 0: 114 isolated cumulative, 54 identical in round (single-phase)

## Observed: 42/49 flags
  4 solo, 38 via combination
  7 additional error-differentiated
  1 behavioral aliases detected

Aliases: -A = --after-context, -B = --before-context, -C = --context, -D = --devices, -E = --extended-regexp, -F = --fixed-strings, -G = --basic-regexp, -H = --with-filename, -L = --files-without-match, -P = --perl-regexp, -R = --dereference-recursive, -T = --initial-tab, -U = --binary, -Z = --null, -a = --text, -b = --byte-offset, -c = --count, -d = --directories, -e = --regexp, -f = --file, -h = --no-filename, -i = --ignore-case, -l = --files-with-matches, -m = --max-count, -n = --line-number, -o = --only-matching, -r = --recursive, -s = --no-messages, -v = --invert-match, -w = --word-regexp, -x = --line-regexp, -z = --null-data

## Solo (unique behavior)
  -A  # print NUM lines of trailing context
    exemplar: "-A" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -B  # print NUM lines of leading context
    exemplar: "-B" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -C  # print NUM lines of output context
    exemplar: "-C" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -d  # how to handle directories;
    exemplar: "-d" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -f  # take PATTERNS from FILE

## Via combination (distinguishable when paired)
  --binary-files  e.g. "-d" "--binary-files=auto" "$(head -n1 input.txt)" "input.txt"
  --color  e.g. "-d" "--color" "$(head -n1 input.txt)" "input.txt"
  --colour  e.g. "-f" "--colour" "$(head -n1 input.txt)" "input.txt"
  --exclude  e.g. "-f" "--exclude=glob" "$(head -n1 input.txt)" "input.txt"
  --exclude-dir  e.g. "-d" "--exclude-dir=glob" "$(head -n1 input.txt)" "input.txt"
  --exclude-from  e.g. "-V" "--exclude-from=input.txt" "$(head -n1 input.txt)" "input.txt"
  --group-separator  e.g. "-d" "--group-separator=," "$(head -n1 input.txt)" "input.txt"
  --include  e.g. "-s" "--include=glob" "$(head -n1 input.txt)" "input.txt"
  --label  e.g. "-f" "--label=test" "$(head -n1 input.txt)" "input.txt"
  --line-buffered  e.g. "-f" "--line-buffered" "$(head -n1 input.txt)" "input.txt"
  --no-group-separator  e.g. "-d" "--no-group-separator" "$(head -n1 input.txt)" "input.txt"
