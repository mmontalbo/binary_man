# Exploration: grep

## Test scope
  163 behavioral groups: 55 unique, 108 shared

  Contexts referenced below:
    empty_dir:
      (empty directory)
    numbers_minimal:
      write "input.txt" "0\n1\n1.00\n$1.00\n1/2\n1E2\n1E02\n1E+02\n-1\n-1.00\n-$1...."
      write "other.txt" "hello world"
      write "old.txt" "ancient"
      props "old.txt" mtime old
      write "big.bin" "<generated 10000 bytes>"
    numbers_standard:
      write "input.txt" "0\n1\n1.00\n$1.00\n1/2\n1E2\n1E02\n1E+02\n-1\n-1.00\n-$1...."
      write "other.txt" "other content\nsecond line"
      write "a.txt" "first"
      write "b.txt" "second"
      write ".hidden" "secret"
      mkdir "subdir"
      write "subdir/nested.txt" "nested"
      symlink "link.txt" -> "input.txt"
      write "exec.sh" "#!/bin/sh
echo hello"
      props "exec.sh" executable
    words_standard:
      write "input.txt" "aardvark\nabbreviation\nabout\nabstract\naccept\naccepted..."
      write "other.txt" "other content\nsecond line"
      write "a.txt" "first"
      write "b.txt" "second"
      write ".hidden" "secret"
      mkdir "subdir"
      write "subdir/nested.txt" "nested"
      symlink "link.txt" -> "input.txt"
      write "exec.sh" "#!/bin/sh
echo hello"
      props "exec.sh" executable
      write "readonly.dat" "protected"
      props "readonly.dat" readonly
      write "-rf" "flag-like filename"

## Observed: 49/49 flags
  6 uniquely observable, 43 distinguishable via flag pairs
  robustness: 72 verified in all contexts, 0 in most, 0 context-dependent

Aliases: -A = --after-context, -B = --before-context, -C = --context, -D = --devices, -E = --extended-regexp, -F = --fixed-strings, -G = --basic-regexp, -H = --with-filename, -L = --files-without-match, -P = --perl-regexp, -R = --dereference-recursive, -T = --initial-tab, -U = --binary, -Z = --null, -a = --text, -b = --byte-offset, -c = --count, -d = --directories, -e = --regexp, -f = --file, -h = --no-filename, -i = --ignore-case, -l = --files-with-matches, -m = --max-count, -n = --line-number, -o = --only-matching, -r = --recursive, -s = --no-messages, -v = --invert-match, -w = --word-regexp, -x = --line-regexp, -z = --null-data

## Verified behavior (flag produced observable output)
  --exclude-from  # skip files that match any file pattern from FILE
    tested: "--exclude-from=other.txt" "$(head -n1 input.txt)" "input.txt" in empty_dir
    | stderr changed: grep: other.txt: No such file or directory
  -A  # print NUM lines of trailing context
    tested: "-A" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard
    | flag adds 11 lines: 1, 1/2, --, -1, -1/2
    | 48 lines unchanged
    without flag:
      0
      1.00
      $1.00
      1E02
      1E+02
      -1.00
            ... (42 more)
    with flag:
      0
      1
      1.00
      $1.00
      1/2
      --
            ... (53 more)
  -B  # print NUM lines of leading context
    tested: "-B" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard
    | flag adds 11 lines: 1, --, 1E2, -1, --
    | 48 lines unchanged
    without flag:
      0
      1.00
      $1.00
      1E02
      1E+02
      -1.00
            ... (42 more)
    with flag:
      0
      1
      1.00
      $1.00
      --
      1E2
            ... (53 more)
  -C  # print NUM lines of output context
    tested: "-C" "1" "$(head -n1 input.txt)" "input.txt" in numbers_standard
    | flag adds 12 lines: 1, 1/2, 1E2, -1, -1/2
    | 48 lines unchanged
    without flag:
      0
      1.00
      $1.00
      1E02
      1E+02
      -1.00
            ... (42 more)
    with flag:
      0
      1
      1.00
      $1.00
      1/2
      1E2
            ... (54 more)
  -d  # how to handle directories; ACTION is 'read', 'recurse', or 'skip'
    tested: "--directories=1" "$(head -n1 input.txt)" "input.txt" in words_standard
    | flag removes 1 lines: aardvark
    | exit: 0 → 1
    | stderr: grep: invalid argument '1' for '--directories'
    without flag:
      aardvark
    with flag:
  -m  # stop after NUM selected lines
    tested: "-m" "2" "$(head -n1 input.txt)" "input.txt" in numbers_minimal
    | flag removes 46 lines: $1.00, 1E02, 1E+02, -1.00, -$1.00
    | 2 lines unchanged
    without flag:
            ... (1 identical)
      1.00
      $1.00
      1E02
      1E+02
      -1.00
      -$1.00
            ... (41 more)
    with flag:
            ... (1 identical)
      1.00

## Distinguishable in combination (verified via flag pairs)
  --binary-files  # assume that binary files are TYPE; TYPE is 'binary', 'text', or 'without-match'
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  --color
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
