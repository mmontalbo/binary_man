  --line-buffered  # flush output on every line
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  --no-group-separator  # do not print separator for matches with context
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  --no-ignore-case  # do not ignore case distinctions (default)
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  --quiet
    | flag removes 1 lines: aardvark
    proven via: (pairwise evidence)
  --silent
    | flag removes 1 lines: aardvark
    proven via: (pairwise evidence)
  -1
    | flag removes 1 lines: aardvark
    | exit: 0 → 2
    | stderr: grep: -1: invalid context length argument
    proven via: "-B" "-1" "$(head -n1 input.txt)" "input.txt"
  -D  # how to handle devices, FIFOs and sockets; ACTION is 'read' or 'skip'
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: read: No such file or directory
    proven via: (pairwise evidence)
  -E  # PATTERNS are extended regular expressions
    | flag removes 1 lines: aardvark
    | exit: 0 → 2
    | stderr: grep: conflicting matchers specified
    proven via: (pairwise evidence)
  -F  # PATTERNS are strings
    | flag removes 1 lines: aardvark
    | exit: 0 → 2
    | stderr: grep: conflicting matchers specified
    proven via: (pairwise evidence)
  -G  # PATTERNS are basic regular expressions
    | flag removes 1 lines: aardvark
    | exit: 0 → 2
    | stderr: grep: conflicting matchers specified
    proven via: (pairwise evidence)
  -H  # print file name with output lines
    | flag adds 1 lines: input.txt:0
    | flag removes 1 lines: 0
    proven via: (pairwise evidence)
  -I  # equivalent to --binary-files=without-match
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: "-e" "-I" "$(head -n1 input.txt)" "input.txt"
  -L  # print only names of FILEs with no selected lines
    | flag removes 1 lines: aardvark
    proven via: (pairwise evidence)
  -P  # PATTERNS are Perl regular expressions
    | flag removes 1 lines: aardvark
    | exit: 0 → 2
    | stderr: grep: conflicting matchers specified
    proven via: (pairwise evidence)
  -R  # likewise, but follow all symlinks
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  -T  # make tabs line up (if needed)
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  -U  # do not strip CR characters at EOL (MSDOS/Windows)
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  -V  # display version information and exit
    | flag adds 10 lines: grep (GNU grep) 3.11, Copyright (C) 2023 Free Software Foundation, Inc., License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>., This is free software: you are free to change and redistribute it., There is NO WARRANTY, to the extent permitted by law.
    | exit: 1 → 0
    proven via: "-f" "/dev/null" "-V" "$(head -n1 input.txt)" "input.txt"
  -Z  # print 0 byte after FILE name
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
    | exit: 0 → 2
    | stderr: grep: root:x:0:0:root:/root:/bin/bash: No such file or directory
    proven via: (pairwise evidence)
  -a  # equivalent to --binary-files=text
    | flag removes 1 lines: root:x:0:0:root:/root:/bin/bash
