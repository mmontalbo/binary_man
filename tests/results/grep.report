# Exploration: grep

## Rounds
  round 0: 35 isolated cumulative, 17 identical in round (discovery)
  round 1: 45 isolated cumulative, 29 identical in round (refinement)
  round 2: 53 isolated cumulative, 35 identical in round (refinement)
  round 3: 63 isolated cumulative, 39 identical in round (refinement)

## Observed: 34/49 flags
  15 solo, 19 via combination
  6 additional error-differentiated
  1 behavioral aliases detected
  8 indistinguishable under tested conditions

Aliases: -A = --after-context, -B = --before-context, -C = --context, -D = --devices, -E = --extended-regexp, -F = --fixed-strings, -G = --basic-regexp, -H = --with-filename, -L = --files-without-match, -P = --perl-regexp, -R = --dereference-recursive, -T = --initial-tab, -U = --binary, -Z = --null, -a = --text, -b = --byte-offset, -c = --count, -d = --directories, -e = --regexp, -f = --file, -h = --no-filename, -i = --ignore-case, -l = --files-with-matches, -m = --max-count, -n = --line-number, -o = --only-matching, -r = --recursive, -s = --no-messages, -v = --invert-match, -w = --word-regexp, -x = --line-regexp, -z = --null-data

## Solo (unique behavior)
  --binary-files  # assume that binary files are TYPE;
  --include  # search only files that match GLOB (a file pattern)
    exemplar: "--include=glob" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (different)
    base:
      cherry
    flag:
  -A  # print NUM lines of trailing context
    exemplar: "-A" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -B  # print NUM lines of leading context
    exemplar: "-B" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -C  # print NUM lines of output context
    exemplar: "-C" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
  -D  # how to handle devices, FIFOs and sockets;
  -H  # print file name with output lines
    exemplar: "-H" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (-1 lines)
    base:
      cherry
    flag:
      input.txt:cherry
  -L  # print only names of FILEs with no selected lines
    exemplar: "-L" "$(head -n1 input.txt)" "input.txt" in numeric_standard / input.txt=empty (+1 lines, exit 0→1)
    base:
    flag:
      input.txt
  -V  # display version information and exit
    exemplar: "-V" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (different)
    base:
      cherry
    flag:
      grep (GNU grep) 3.11
      Copyright (C) 2023 Free Software Foundation, Inc.
      License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.
      This is free software: you are free to change and redistribute it.
      There is NO WARRANTY, to the extent permitted by law.
            ...
  -b  # print the byte offset with output lines
    exemplar: "-b" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (-1 lines)
    base:
      cherry
    flag:
      0:cherry
  -c  # print only a count of selected lines per FILE
    exemplar: "-c" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (different)
    base:
      cherry
    flag:
      1
  -d  # how to handle directories;
    exemplar: "-d" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (different)
    base:
      cherry
    flag:
  -f  # take PATTERNS from FILE
  -l  # print only names of FILEs with selected lines
    exemplar: "-l" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (different)
    base:
      cherry
    flag:
      input.txt
  -m  # stop after NUM selected lines
    exemplar: "-m" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different, exit 2→1)
    base:
      100
      1000
    flag:
  -n  # print line number with output lines
    exemplar: "-n" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (-1 lines)
    base:
      cherry
    flag:
      1:cherry
  -s  # suppress error messages
    exemplar: "-s" "$(head -n1 input.txt)" "input.txt" in numeric_minimal (different)
    base:
      100
      1000
    flag:
      100
      1000
  -v  # select non-matching lines
    exemplar: "-v" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (+6 lines, exit 1→0)
    base:
      cherry
    flag:
      Apple
      banana
      Date
      elderberry
      BANANA
            ...
  -z  # a data line ends in 0 byte, not newline
    exemplar: "-z" "$(head -n1 input.txt)" "input.txt" in alpha_minimal (-9 lines)
    base:
      cherry
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...

