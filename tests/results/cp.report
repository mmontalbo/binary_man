  --strip-trailing-slashes  e.g. "--remove-destination" "--strip-trailing-slashes" "input.txt" "other.txt"
  --update  e.g. "--debug" "--preserve" "--update" "input.txt" "other.txt"
  -H  e.g. (pairwise evidence)
  -L  e.g. (pairwise evidence)
  -R  e.g. (pairwise evidence)
  -Z  e.g. (pairwise evidence)
