# Exploration: cp

## Rounds
  round 0: 35 isolated cumulative, 14 identical in round (discovery)
  round 1: 46 isolated cumulative, 21 identical in round (refinement)
  round 2: 54 isolated cumulative, 25 identical in round (refinement)
  round 3: 62 isolated cumulative, 31 identical in round (refinement)

## Observed: 30/36 flags
  12 solo, 18 via combination
  2 additional error-differentiated
  1 behavioral aliases detected
  4 indistinguishable under tested conditions

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --attributes-only  # don't copy the file data, just the attributes
    exemplar: "--attributes-only" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "subdir" in alpha_minimal (reordered)
    base:
    flag:
      'input.txt' -> 'subdir'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=attr_list" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before
    exemplar: "--remove-destination" in alpha_minimal (different)
    base:
      (no base)
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -T  # treat DEST as a normal file
    exemplar: "-T" "input.txt" "subdir" in alpha_minimal (different, exit 1→0)
    base:
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -i  # prompt before overwrite (overrides a previous -n
    exemplar: "-i" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -l  # hard link files instead of copying
    exemplar: "-l" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -s  # make symbolic links instead of copying
    exemplar: "-s" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

## Via combination (distinguishable when paired)
  --backup  e.g. "--verbose" "--backup" "--keep-directory-symlink" "--strip-trailing-slashes" "input.txt" "other.txt"
  --context  e.g. "--remove-destination" "--context" "--keep-directory-symlink" "input.txt" "other.txt"
  --copy-contents  e.g. "--remove-destination" "--copy-contents" "input.txt" "other.txt"
  --keep-directory-symlink  e.g. "--verbose" "--backup" "--keep-directory-symlink" "--strip-trailing-slashes" "input.txt" "other.txt"
  --preserve  e.g. "--verbose" "--backup" "--preserve" "input.txt" "other.txt"
  --recursive  e.g. "--remove-destination" "--backup" "--recursive" "input.txt" "other.txt"
  --sparse  e.g. (pairwise evidence)
  --strip-trailing-slashes  e.g. "--verbose" "--backup" "--keep-directory-symlink" "--strip-trailing-slashes" "input.txt" "other.txt"
  --update  e.g. "--suffix=test" "--backup" "--keep-directory-symlink" "--update" "input.txt" "other.txt"
  -H  e.g. (pairwise evidence)
  -L  e.g. (pairwise evidence)
