# Exploration: cp

## Rounds
  round 0: 63 isolated cumulative, 19 identical in round (single-phase)

## Observed: 34/36 flags
  8 solo, 26 via combination
  2 additional error-differentiated

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --backup
    exemplar: "--backup" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=attr_list" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before
    exemplar: "--remove-destination" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

## Via combination (distinguishable when paired)
  --attributes-only  e.g. "--attributes-only" "--parents" "input.txt" "subdir"
  --context  e.g. "-t" "--context" "input.txt" "subdir"
  --copy-contents  e.g. "-t" "--copy-contents" "input.txt" "subdir"
  --keep-directory-symlink  e.g. "-t" "--keep-directory-symlink" "input.txt" "subdir"
  --preserve  e.g. "-t" "--preserve" "input.txt" "subdir"
  --recursive  e.g. "-t" "--recursive" "input.txt" "subdir"
  --sparse  e.g. "-t" "--sparse=auto" "input.txt" "subdir"
  --strip-trailing-slashes  e.g. "-t" "--strip-trailing-slashes" "input.txt" "subdir"
  --update  e.g. "-t" "--update" "input.txt" "subdir"
  -H  e.g. "-t" "-H" "input.txt" "subdir"
  -L  e.g. "-t" "-L" "input.txt" "subdir"
  -P  e.g. "-t" "-P" "input.txt" "subdir"
  -R  e.g. "-t" "-R" "input.txt" "subdir"
  -T  e.g. "-T" "--attributes-only" "input.txt" "subdir"
  -Z  e.g. "-t" "-Z" "input.txt" "subdir"
  -a  e.g. "-t" "-a" "input.txt" "subdir"
  -d  e.g. "-t" "-d" "input.txt" "subdir"
  -f  e.g. "-t" "-f" "input.txt" "subdir"
  -i  e.g. "-t" "-i" "input.txt" "subdir"
  -l  e.g. "-l" "-s" "input.txt" "subdir"
  -n  e.g. "-t" "-n" "input.txt" "subdir"
  -p  e.g. "-t" "-p" "input.txt" "subdir"
  -r  e.g. "-t" "-r" "input.txt" "subdir"
  -s  e.g. "-l" "-s" "input.txt" "subdir"
  -u  e.g. "-t" "-u" "input.txt" "subdir"
  -x  e.g. "-t" "-x" "input.txt" "subdir"

