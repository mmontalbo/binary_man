# Exploration: cp

## Rounds
  round 0: 57 isolated cumulative, 28 identical in round (single-phase)

## Observed: 36/36 flags
  19 solo, 17 via combination
  3 behavioral aliases detected
  robustness: 34 robust, 0 moderate, 0 fragile

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --attributes-only  # don't copy the file data, just the attributes
    exemplar: "--attributes-only" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --backup
    exemplar: "--backup" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --copy-contents  # copy contents of special files when recursive
    exemplar: "--copy-contents" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=mode" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in syslog_minimal (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before attempting to open it (contrast with --force)
    exemplar: "--remove-destination" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --sparse  # control creation of sparse files. See below
    exemplar: "--sparse=auto" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  --strip-trailing-slashes  # remove any trailing slashes from each SOURCE argument
    exemplar: "--strip-trailing-slashes" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -H  # follow command-line symbolic links in SOURCE
    exemplar: "-H" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -L  # always follow symbolic links in SOURCE
    exemplar: "-L" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -P  # never follow symbolic links in SOURCE
    exemplar: "-P" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "test" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -d  # same as --no-dereference --preserve=links
    exemplar: "-d" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -f  # if an existing destination file cannot be opened, remove it and try again (this option is ignored when the -n option is also used)
    exemplar: "-f" "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "." "input.txt" "other.txt" in words_standard (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

