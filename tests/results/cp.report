# Exploration: cp

## Rounds
  round 0: 40 isolated cumulative, 41 identical in round (single-phase)

## Observed: 35/36 flags
  10 solo, 25 via combination
  1 additional error-differentiated
  2 behavioral aliases detected

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=1" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before attempting to open it (contrast with --force)
    exemplar: "--remove-destination" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -L  # always follow symbolic links in SOURCE
    exemplar: "-L" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -P  # never follow symbolic links in SOURCE
    exemplar: "-P" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "test" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -f  # if an existing destination file cannot be opened, remove it and try again (this option is ignored when the -n option is also used)
    exemplar: "-f" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "." "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in words_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

