# Exploration: cp

## Rounds
  round 0: 24 isolated cumulative, 8 identical in round (discovery)
  round 1: 36 isolated cumulative, 21 identical in round (refinement)
  round 2: 44 isolated cumulative, 28 identical in round (refinement)
  round 3: 59 isolated cumulative, 28 identical in round (refinement)

## Observed: 31/36 flags
  14 solo, 17 via combination
  2 additional error-differentiated
  1 behavioral aliases detected
  2 indistinguishable under tested conditions

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --attributes-only  # don't copy the file data, just the attributes
    exemplar: "--attributes-only" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --backup
    exemplar: "--backup" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --context
    exemplar: "--context" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=attr_list" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  --remove-destination  # remove each existing destination file before
    exemplar: "--remove-destination" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -P  # never follow symbolic links in SOURCE
    exemplar: "-P" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "subdir" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -f  # if an existing destination file cannot be
    exemplar: "-f" "input.txt" "subdir" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "input.txt" "subdir" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -u  # equivalent to --update[=older].  See below
    exemplar: "-u" "input.txt" "subdir" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in many_files /remove subdir (different)
    base:
      (no base)
    flag:
      'input.txt' -> 'other.txt'
  -x  # stay on this file system
    exemplar: "-x" "input.txt" "subdir" in many_files /remove subdir (different)
    base:
      (no base)
    flag:

