# Exploration: cp

## Rounds
  round 0: 34 isolated cumulative, 11 identical in round (discovery)
  round 1: 38 isolated cumulative, 19 identical in round (refinement)
  round 2: 50 isolated cumulative, 26 identical in round (refinement)
  round 3: 59 isolated cumulative, 29 identical in round (refinement)

## Observed: 30/36 flags
  14 solo, 16 via combination
  3 additional error-differentiated
  3 indistinguishable under tested conditions

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --attributes-only  # don't copy the file data, just the attributes
    exemplar: "--attributes-only" in alpha_minimal (different)
    base:
      (no base)
    flag:
  --backup
    exemplar: "--backup" in alpha_minimal (different)
    base:
      (no base)
    flag:
  --copy-contents  # copy contents of special files when recursive
    exemplar: "--copy-contents" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=attr_list" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" in alpha_minimal (different)
    base:
      (no base)
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before
    exemplar: "--remove-destination" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -P  # never follow symbolic links in SOURCE
    exemplar: "-P" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -T  # treat DEST as a normal file
    exemplar: "-T" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -i  # prompt before overwrite (overrides a previous -n
    exemplar: "-i" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -l  # hard link files instead of copying
    exemplar: "-l" "input.txt" "subdir" in alpha_minimal (different)
    base:
    flag:
  -s  # make symbolic links instead of copying
    exemplar: "-s" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

