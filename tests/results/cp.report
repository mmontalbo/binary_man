# Exploration: cp

## Rounds
  round 0: 34 isolated cumulative, 11 identical in round (discovery)
  round 1: 36 isolated cumulative, 19 identical in round (refinement)
  round 2: 41 isolated cumulative, 31 identical in round (refinement)
  round 3: 51 isolated cumulative, 37 identical in round (refinement)

## Distinguished: 33/36 flags
  30 observed behavior (13 solo, 17 via combination)
  3 error-differentiated only (3 solo, 0 via combination)
  2 behavioral aliases detected
  3 indistinguishable under tested conditions

Aliases: -L = --dereference, -P = --no-dereference, -S = --suffix, -T = --no-target-directory, -a = --archive, -f = --force, -i = --interactive, -l = --link, -n = --no-clobber, -s = --symbolic-link, -t = --target-directory, -v = --verbose, -x = --one-file-system

## Solo (unique behavior)
  --attributes-only  # don't copy the file data, just the attributes
    exemplar: "--attributes-only" "input.txt" "subdir" in empty_dir (different, exit 0→1)
    base:
    flag:
  --debug  # explain how a file is copied.  Implies -v
    exemplar: "--debug" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'
      copy offload: yes, reflink: unsupported, sparse detection: no
  --no-preserve  # don't preserve the specified attributes
    exemplar: "--no-preserve=attr_list" "input.txt" "subdir" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  --parents  # use full source file name under DIRECTORY
    exemplar: "--parents" "input.txt" "subdir" in alpha_standard (different, exit 1→0)
    base:
    flag:
  --reflink
    exemplar: "--reflink" "input.txt" "other.txt" in empty_dir (different)
    base:
    flag:
  --remove-destination  # remove each existing destination file before
    exemplar: "--remove-destination" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -L  # always follow symbolic links in SOURCE
    exemplar: "-L" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -P  # never follow symbolic links in SOURCE
    exemplar: "-P" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -S  # override the usual backup suffix
    exemplar: "-S" "input.txt" "other.txt" in numeric_standard / env COLUMNS=40 (different, exit 1→127)
    base:
    flag:
  -T  # treat DEST as a normal file
    exemplar: "-T" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -b  # like --backup but does not accept an argument
    exemplar: "-b" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
  -i  # prompt before overwrite (overrides a previous -n
    exemplar: "-i" "input.txt" "subdir" in alpha_standard (different)
    base:
    flag:
  -l  # hard link files instead of copying
    exemplar: "-l" "input.txt" "subdir" in alpha_standard (different)
    base:
    flag:
  -s  # make symbolic links instead of copying
    exemplar: "-s" "input.txt" "subdir" in empty_dir (different)
    base:
    flag:
  -t  # copy all SOURCE arguments into DIRECTORY
    exemplar: "-t" "input.txt" "other.txt" in empty_dir (different)
    base:
    flag:
  -v  # explain what is being done
    exemplar: "-v" "input.txt" "other.txt" in alpha_minimal (different)
    base:
    flag:
      'input.txt' -> 'other.txt'

