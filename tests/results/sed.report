## Solo (unique behavior)
  --debug
    exemplar: "--debug" "input.txt" "other.txt" in alpha_minimal (-7 lines)
    base:
      nput.txt
      hello world
    flag:
      SED PROGRAM:
        i\nput.txt
      
      INPUT:   'other.txt' line 1
      PATTERN: hello world
            ...
  --follow-symlinks
    exemplar: "--follow-symlinks" "alpha" "input.txt" in alpha_minimal (-18 lines)
    base:
      cherry
      lpha
      Apple
      lpha
      banana
            ...
    flag:
      cherry
      lpha
      Apple
      lpha
      banana
            ...
  --in-place
