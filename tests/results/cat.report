# Exploration: cat

## Rounds
  round 0: 33 isolated cumulative, 49 identical in round (single-phase)

## Observed: 10/10 flags
  3 solo, 7 via combination

Aliases: -A = --show-all, -E = --show-ends, -T = --show-tabs, -b = --number-nonblank, -n = --number, -s = --squeeze-blank, -v = --show-nonprinting

## Solo (unique behavior)
  -e  # equivalent to -vE
    exemplar: "-e" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces   
            ...
    flag:
      first line$
      $
      $
      	indented with tab$
      trailing spaces   $
            ...
  -t  # equivalent to -vT
    exemplar: "-t" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces   
            ...
    flag:
      first line
      
      
      ^Iindented with tab
      trailing spaces   
            ...
  -u  # (ignored)
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (-4 lines)
    base:
      first line
      
      
      	indented with tab
      trailing spaces   
            ...
    flag:
      first line
      
      
      	indented with tab
      trailing spaces   
            ...

## Via combination (distinguishable when paired)
  -A  e.g. "-A" "-b" "$(head -n1 input.txt)" "input.txt"
  -E  e.g. "-E" "-T" "$(head -n1 input.txt)" "input.txt"
  -T  e.g. "-n" "-T" "$(head -n1 input.txt)" "input.txt"
  -b  e.g. "-b" "-v" "$(head -n1 input.txt)" "input.txt"
  -n  e.g. "-n" "-T" "$(head -n1 input.txt)" "input.txt"
  -s  e.g. "-s" "-t" "$(head -n1 input.txt)" "input.txt"
  -v  e.g. "-n" "-v" "$(head -n1 input.txt)" "input.txt"

