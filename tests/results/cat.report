           3	banana
           4	Date
           5	elderberry
            ...
  -s  # suppress repeated empty output lines
    exemplar: "-s" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -t  # equivalent to -vT
    exemplar: "-t" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -u  # (ignored)
    exemplar: "-u" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -v  # use ^ and M- notation, except for LFD and TAB
    exemplar: "-v" "input.txt" "other.txt" in alpha_minimal (-10 lines)
