# Exploration: cat

## Rounds
  round 0: 33 isolated cumulative, 49 identical in round (single-phase)

## Observed: 10/10 flags
  3 solo, 7 via combination

Aliases: -A = --show-all, -E = --show-ends, -T = --show-tabs, -b = --number-nonblank, -n = --number, -s = --squeeze-blank, -v = --show-nonprinting

## Solo (unique behavior)
  -e  # equivalent to -vE
    exemplar: "-e" "input.txt" "other.txt" in paths_minimal (-30 lines)
    base:
      /usr/local/bin/python3
      /usr/bin/env
      /bin/sh
      /home/alice/.bashrc
      /home/alice/.config/nvim/init.lua
            ...
    flag:
      /usr/local/bin/python3$
      /usr/bin/env$
      /bin/sh$
      /home/alice/.bashrc$
      /home/alice/.config/nvim/init.lua$
            ...
  -t  # equivalent to -vT
    exemplar: "-t" "input.txt" "other.txt" in paths_minimal (-30 lines)
    base:
      /usr/local/bin/python3
      /usr/bin/env
      /bin/sh
      /home/alice/.bashrc
      /home/alice/.config/nvim/init.lua
            ...
    flag:
      /usr/local/bin/python3
      /usr/bin/env
      /bin/sh
      /home/alice/.bashrc
      /home/alice/.config/nvim/init.lua
            ...
  -u  # (ignored)
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (-48 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...

## Via combination (distinguishable when paired)
  -A  e.g. "-A" "-n" "$(head -n1 input.txt)" "input.txt"
  -E  e.g. "-b" "-E" "$(head -n1 input.txt)" "input.txt"
  -T  e.g. "-b" "-T" "$(head -n1 input.txt)" "input.txt"
  -b  e.g. "-b" "-E" "$(head -n1 input.txt)" "input.txt"
  -n  e.g. "-n" "-v" "$(head -n1 input.txt)" "input.txt"
  -s  e.g. "-e" "-s" "$(head -n1 input.txt)" "input.txt"
  -v  e.g. "-n" "-v" "$(head -n1 input.txt)" "input.txt"

