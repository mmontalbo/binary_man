# Exploration: cat

## Rounds
  round 0: 14 isolated cumulative, 49 identical in round (discovery)
  round 1: 74 isolated cumulative, 30 identical in round (refinement)
  round 2: 74 isolated cumulative, 29 identical in round (refinement)

## Distinguished: 10/10 flags
  10 observed behavior (10 solo, 0 via combination)

Aliases: -A = --show-all, -E = --show-ends, -T = --show-tabs, -b = --number-nonblank, -n = --number, -s = --squeeze-blank, -v = --show-nonprinting

## Solo (unique behavior)
  -A  # equivalent to -vET
    exemplar: "-A" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry$
      Apple$
      banana$
      Date$
      elderberry$
            ...
  -E  # display $ at end of each line
    exemplar: "-E" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry$
      Apple$
      banana$
      Date$
      elderberry$
            ...
  -T  # display TAB characters as ^I
    exemplar: "-T" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
  -b  # number nonempty output lines, overrides -n
    exemplar: "-b" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
           1	cherry
           2	Apple
           3	banana
           4	Date
           5	elderberry
            ...
  -e  # equivalent to -vE
    exemplar: "-e" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
      cherry$
      Apple$
      banana$
      Date$
      elderberry$
            ...
  -n  # number all output lines
    exemplar: "-n" "input.txt" "other.txt" in alpha_minimal (-10 lines)
    base:
      cherry
      Apple
      banana
      Date
      elderberry
            ...
    flag:
           1	cherry
