# Exploration: cat

## Rounds
  round 0: 12 isolated cumulative, 70 identical in round (single-phase)

## Observed: 10/10 flags
  3 solo, 7 via combination
  robustness: 10 robust, 0 moderate, 0 fragile

Aliases: -A = --show-all, -E = --show-ends, -T = --show-tabs, -b = --number-nonblank, -n = --number, -s = --squeeze-blank, -v = --show-nonprinting

## Solo (unique behavior)
  -e  # equivalent to -vE
    exemplar: "-e" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line$
      second line with trailing spaces$
      	indented with tab$
          indented with spaces$
      	 	mixed tabs and spaces$
            ...
  -t  # equivalent to -vT
    exemplar: "-t" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line
      second line with trailing spaces
      ^Iindented with tab
          indented with spaces
      ^I ^Imixed tabs and spaces
            ...
  -u  # (ignored)
    exemplar: "-u" "input.txt" "other.txt" in formatted_minimal (-45 lines)
    base:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...
    flag:
      first line
      second line with trailing spaces
      	indented with tab
          indented with spaces
      	 	mixed tabs and spaces
            ...

## Via combination (distinguishable when paired)
  -A  e.g. (pairwise evidence)
  -E  e.g. (pairwise evidence)
  -T  e.g. (pairwise evidence)
  -b  e.g. (pairwise evidence)
