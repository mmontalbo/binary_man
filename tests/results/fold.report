# Exploration: fold

## Rounds
  round 0: 14 isolated cumulative, 27 identical in round (single-phase)

## Observed: 3/3 flags
  1 solo, 2 via combination

Aliases: -b = --bytes, -s = --spaces, -w = --width

## Solo (unique behavior)
  -w  # use WIDTH columns instead of 80
    exemplar: "-w" in numbers_minimal (different)
    base:
    flag:

## Via combination (distinguishable when paired)
  -b  e.g. "-w" "-b" "$(head -n1 input.txt)" "input.txt"
  -s  e.g. "-w" "-s" "$(head -n1 input.txt)" "input.txt"

