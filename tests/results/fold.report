# Exploration: fold

## Rounds
  round 0: 59 isolated cumulative, 33 identical in round (single-phase)

## Observed: 3/3 flags
  3 solo, 0 via combination

Aliases: -b = --bytes, -s = --spaces, -w = --width

## Solo (unique behavior)
  -b  # count bytes rather than columns
    exemplar: "-b" "input.txt" "other.txt" in passwd_minimal (-42 lines)
    base:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
    flag:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
  -s  # break at spaces
    exemplar: "-s" "input.txt" "other.txt" in passwd_minimal (-42 lines)
    base:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
    flag:
      root:x:0:0:root:/root:/bin/bash
      daemon:x:1:1:daemon:/usr/sbin:/usr/sbin/nologin
      bin:x:2:2:bin:/bin:/usr/sbin/nologin
      sys:x:3:3:sys:/dev:/usr/sbin/nologin
      sync:x:4:65534:sync:/bin:/bin/sync
            ...
  -w  # use WIDTH columns instead of 80
    exemplar: "-w" "2" in words_minimal / stdin (+9 lines)
    base:
      cherry
      apple
      banana
    flag:
      ch
      er
      ry
      ap
      pl
            ...

